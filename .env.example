# Flow/Doku:
# - docs/project/BOARD_UMSETZUNGSFREIGABE_SECRET_ENV_2026-03-10.md
# - docs/project/RUNBOOK_SECRET_SYNC_VDAN_FCP_2026-03-10.md
# - docs/project/SECRET_MATRIX_VDAN_FCP_2026-03-10.md

# Public (safe to expose in client/bundle)
# Quelle:
# - PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY:
#   Supabase Dashboard -> Settings -> API
# - PUBLIC_MEMBER_CARD_VERIFY_PUBKEY:
#   oeffentlicher Verifikationsschluessel (kein Secret)
# - PUBLIC_TURNSTILE_SITE_KEY:
#   Cloudflare Turnstile Dashboard (Site Key)
# - PUBLIC_VAPID_PUBLIC_KEY:
#   Web-Push Public Key
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"
PUBLIC_MEMBER_CARD_VERIFY_PUBKEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
PUBLIC_TURNSTILE_SITE_KEY=""
PUBLIC_VAPID_PUBLIC_KEY=""

# Optional (UI/Branding)
# - PUBLIC_APP_NAME / PUBLIC_APP_BRAND: sichtbarer Name/Branding
# - PUBLIC_SUPERADMIN_USER_IDS: CSV von User IDs fuer UI-Sonderfaelle
# - PUBLIC_APP_THEME: Theme-Schluessel
PUBLIC_APP_NAME="VDAN APP"
PUBLIC_APP_BRAND="VDAN"
PUBLIC_SUPERADMIN_USER_IDS=""
PUBLIC_APP_THEME="vdan_default"

# FCP Prelaunch Guard (serverseitig, nicht PUBLIC)
# Nur wirksam in server output / Vercel runtime.
# FCP_PRELAUNCH_PASSWORD_HASH Format:
# scrypt$<saltBase64url>$<hashBase64url>
FCP_PRELAUNCH_ENABLED="false"
FCP_PRELAUNCH_ALLOWED_HOSTS="www.fishing-club-portal.de,fishing-club-portal.de"
FCP_PRELAUNCH_COOKIE_NAME="fcp_prelaunch"
FCP_PRELAUNCH_COOKIE_SECRET=""
FCP_PRELAUNCH_PASSWORD_HASH=""
