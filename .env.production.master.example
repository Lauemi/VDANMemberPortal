# =========================
# PRODUCTION MASTER (example)
# =========================
# Flow/Doku:
# - docs/project/BOARD_UMSETZUNGSFREIGABE_SECRET_ENV_2026-03-10.md
# - docs/project/RUNBOOK_SECRET_SYNC_VDAN_FCP_2026-03-10.md
# - docs/project/SECRET_MATRIX_VDAN_FCP_2026-03-10.md
#
# Echte Datei lokal: .env.production.master (nicht committen).
# Zielsystem: Vercel Production

# Public config (clientseitig sichtbar)
# Quelle: Supabase Dashboard -> Settings -> API
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Branding/UI (finale Produktionswerte)
PUBLIC_APP_NAME=
PUBLIC_APP_BRAND=
PUBLIC_APP_THEME=
PUBLIC_SUPERADMIN_USER_IDS=
# Runtime-Flags (frontend/public)
PUBLIC_ENABLE_PASSWORD_RESET=
PUBLIC_AUTH_EMAIL_CHANGE_ENABLED=
PUBLIC_OPEN_SELF_REGISTRATION_ENABLED=
PUBLIC_AUTH_ALLOW_LEGACY_MEMBER_LOGIN=
PUBLIC_APP_VERSION=
PUBLIC_APP_CHANNEL=

# Public key material / anti-bot / push
PUBLIC_MEMBER_CARD_VERIFY_PUBKEY=
PUBLIC_TURNSTILE_SITE_KEY=
PUBLIC_VAPID_PUBLIC_KEY=
PUBLIC_SITE_LOCKDOWN=

# Plattform-Konfiguration
FCP_PLATFORM_URL=
VDAN_PUBLIC_HOST=
FCP_SUPPORT_EMAIL=
FCP_DEFAULT_FROM_NAME=

# Runtime Secret (nur wenn serverseitig benoetigt)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PUSH_NOTIFY_TOKEN=
CLIENT_REQUEST_SALT=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# FCP Prelaunch Guard (serverseitig)
FCP_PRELAUNCH_ENABLED=
FCP_PRELAUNCH_ALLOWED_HOSTS=
FCP_PRELAUNCH_COOKIE_NAME=
FCP_PRELAUNCH_COOKIE_SECRET=
FCP_PRELAUNCH_PASSWORD_HASH=
