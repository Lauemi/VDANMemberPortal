    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/.next/**": true,
    "**/.nuxt/**": true,
    "**/.output/**": true,
    "**/platforms/**": true,
    "**/plugins/**": true,
    "**/leaflet/**": true,
    "**/.vercel/**": true,
    "**/.astro/**": true,
    "**/www/dist/**": true
  },
  "search.exclude": {
    "**/build": true,
    "**/dist": true,
    "**/lib": true,
    "**/platforms": true,
    "**/plugins": true,
    "**/leaflet": true,
    "**/node_modules": true,
    "**/coverage": true,
    "**/.next": true,
    "**/.nuxt": true,
    "**/.output": true,
    "**/.astro": true
  },
  "files.exclude": {
