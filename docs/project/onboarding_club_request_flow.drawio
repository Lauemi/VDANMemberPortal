        <mxCell id="16" value="Callback / Session-Auflösung&#xa;/auth/callback/ oder direkte Session&#xa;→ accept legal / bootstrap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;" vertex="1" parent="1">
          <mxGeometry x="1040" y="1260" width="340" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="17" value="Mail 2&#xa;Vereinsanfrage eingegangen / wird geprüft&#xa;Trigger: club-request-submit bei status=pending, auto_approve=false&#xa;Empfänger: requester_email&#xa;Zweck: bestätigt die gespeicherte Anfrage und erklärt die Pending-Sperre&#xa;Wirkung: Nutzer versteht, warum nur /app/anfrage-offen/ verfügbar ist" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#7c3aed;" vertex="1" parent="1">
