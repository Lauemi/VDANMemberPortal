        <mxCell id="8" value="Legacy-Weiterleitungen&#xa;/registrieren/?mode=join_club → /vereinssignin/&#xa;/registrieren/?mode=create_club → /verein-anfragen/&#xa;invite vorhanden → /vereinssignin/?invite=..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;" vertex="1" parent="1">
