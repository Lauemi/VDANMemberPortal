        </mxCell>
        <mxCell id="23" value="Nein / Ablehnung&#xa;Mail 4&#xa;Anfrage abgelehnt&#xa;Trigger: club-request-decision action=reject&#xa;Empfänger: requester_email&#xa;Zweck: Absage transparent machen, optional mit rejection_reason&#xa;Wirkung: beendet den Pending-Fall ohne Portal-Freigabe" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;" vertex="1" parent="1">
