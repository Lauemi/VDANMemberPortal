        <mxCell id="219" value="Nein&#xa;Mail 4&#xa;Anfrage abgelehnt&#xa;Trigger: Admin-Ablehnung&#xa;Empfänger: requester_email&#xa;Zweck: Entscheidung sauber erklären, optional mit Ablehnungsgrund&#xa;Wirkung: kein Portalzugang, Pending-Fall wird fachlich abgeschlossen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;" vertex="1" parent="201">
