        <mxCell id="22" value="Ja&#xa;Mail 3&#xa;Vereinsanfrage freigegeben&#xa;Trigger: club-request-decision action=approve oder auto_approve-Pfad&#xa;Empfänger: requester_email&#xa;Zweck: Freigabe mitteilen und Login-/Portal-Link liefern&#xa;Wirkung: Nutzer darf aus Pending in den Portalzugang wechseln" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#15803d;" vertex="1" parent="1">
