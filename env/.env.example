PUBLIC_SUPABASE_PUBLISHABLE_KEY=REPLACE_ME_OPTIONAL
PUBLIC_VAPID_PUBLIC_KEY=REPLACE_ME
PUBLIC_MEMBER_CARD_VERIFY_PUBKEY=-----BEGIN PUBLIC KEY-----REPLACE_ME-----END PUBLIC KEY-----
PUBLIC_TURNSTILE_SITE_KEY=REPLACE_ME_OPTIONAL

# ---- Server/secret values ----
