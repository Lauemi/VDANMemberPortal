# Fishing-Club-Portal env template
# NOTE: Placeholders only. Never commit real values.

# ---- Public app values (not secret, but env-specific) ----
PUBLIC_APP_NAME=Fishing-Club-Portal
PUBLIC_APP_BRAND=FCP
PUBLIC_APP_CHANNEL=staging
PUBLIC_APP_VERSION=2026.03.02-staging.1
PUBLIC_ENABLE_PASSWORD_RESET=true
PUBLIC_SITE_LOCKDOWN=true

PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
