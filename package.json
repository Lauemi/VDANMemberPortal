{
  "name": "vdan-app-template",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "predev": "npm run generate:fcp-components",
    "dev": "astro dev",
    "prebuild": "npm run generate:fcp-components",
    "build": "astro build",
    "preview": "astro preview",
    "pretest": "npm run generate:fcp-components",
    "test": "node --test",
    "generate:fcp-components": "node scripts/generate-fcp-component-registry.mjs",
    "check:deploy-gate": "node scripts/release-deploy-gate.mjs",
    "check:masks": "node scripts/check-mask-jsons.mjs",
    "check:remote-function-smoke": "node scripts/remote-function-smoke.mjs",
    "check:xss-guard": "node scripts/check-xss-guard.mjs",
    "check:studio-contract": "node scripts/check-studio-contract.mjs",
    "check:governance-health": "node scripts/governance-health-gate.mjs",
    "test:smoke:invite-375": "playwright test -c playwright.config.ts",
    "test:smoke:invite-375:ci": "npm run build && playwright test -c playwright.config.ts --reporter=line",
    "deploy:vercel": "gh workflow run deploy-vercel.yml --ref main",
    "deploy:ionos": "gh workflow run deploy-ionos.yml --ref main",
    "deploy": "npm run deploy:vercel && npm run deploy:ionos",
    "deploy:status": "gh run list --workflow=deploy-vercel.yml --workflow=deploy-ionos.yml --limit 10",
    "report:role-matrix": "node scripts/generate-role-page-matrix-report.mjs",
    "security:fcp-prelaunch-hash": "node scripts/fcp-prelaunch-hash.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/vercel": "^9.0.4",
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
