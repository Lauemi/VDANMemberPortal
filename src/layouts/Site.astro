---
import "../styles/app-shell.css";
import { APP } from "../config/app";
import { resolveSiteMode } from "../config/site-mode";
import { getStaticWebPageEntry, getStaticWebTargetConfig } from "../config/static-web-pages";
import pkg from "../../package.json";

function envText(value: unknown, fallback: string) {
  const text = String(value ?? "").trim();
  return text || fallback;
}

const {
  title = APP.name,
  description = "",
  robots = "index",
  canonical: canonicalProp,
  containerClass = "container",
  density,
  appThemeOverride,
} = Astro.props as {
  title?: string;
  description?: string;
  robots?: string;
  canonical?: string;
  containerClass?: string;
  density?: "comfortable" | "compact";
  appThemeOverride?: string;
};

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? "";
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "";
const memberCardVerifyPubKey = import.meta.env.PUBLIC_MEMBER_CARD_VERIFY_PUBKEY ?? "";
const vapidPublicKey = import.meta.env.PUBLIC_VAPID_PUBLIC_KEY ?? "";
const authEmailChangeEnabled = String(import.meta.env.PUBLIC_AUTH_EMAIL_CHANGE_ENABLED ?? "false").trim().toLowerCase() === "true";
const openSelfRegistrationEnabled = String(import.meta.env.PUBLIC_OPEN_SELF_REGISTRATION_ENABLED ?? "false").trim().toLowerCase() === "true";
const authAllowLegacyMemberLogin = String(import.meta.env.PUBLIC_AUTH_ALLOW_LEGACY_MEMBER_LOGIN ?? "true").trim().toLowerCase() === "true";
const appVersionEnv = String(import.meta.env.PUBLIC_APP_VERSION ?? "").trim();
const pkgVersion = String(pkg?.version || "0.1.0").trim();
const deploySha = envText(
  import.meta.env.PUBLIC_DEPLOY_SHA,
  envText(import.meta.env.VERCEL_GIT_COMMIT_SHA, envText(import.meta.env.GITHUB_SHA, "")),
);
const deployRef = envText(
  import.meta.env.PUBLIC_DEPLOY_REF,
  envText(import.meta.env.VERCEL_GIT_COMMIT_REF, envText(import.meta.env.GITHUB_REF_NAME, "")),
);
const buildStamp = envText(import.meta.env.PUBLIC_BUILD_STAMP, "");
const autoAppVersion = [
  `v${pkgVersion}`,
  deployRef ? deployRef.replace(/[^a-zA-Z0-9._-]+/g, "-") : "",
  deploySha ? deploySha.slice(0, 7) : buildStamp || "dev-local",
].filter(Boolean).join("+");
const appVersion = appVersionEnv && appVersionEnv !== "dev-local" ? appVersionEnv : autoAppVersion;
const appChannel = String(import.meta.env.PUBLIC_APP_CHANNEL ?? "beta").trim().toLowerCase();
const isBetaChannel = appChannel === "beta";
const assetVersion = encodeURIComponent(appVersion);
const resolvedSiteMode = resolveSiteMode(Astro.url.hostname, APP.siteMode);
const isFcpMode = resolvedSiteMode === "fcp";
const path = Astro.url.pathname.toLowerCase();
const isAppPath = path.startsWith("/app/");
const staticPageEntry = !isAppPath ? getStaticWebPageEntry(path) : null;
const staticPageTarget = staticPageEntry ? getStaticWebTargetConfig(path, resolvedSiteMode) : null;
const staticPageVisible = staticPageTarget ? staticPageTarget.visible !== false : true;
const staticPageInitialBrand = staticPageTarget?.brand || resolvedSiteMode;
const staticPageBlocked = Boolean(staticPageEntry && !staticPageVisible);
if (staticPageBlocked) {
  Astro.response.status = 404;
}
const runtimeSiteName = isFcpMode ? "Fishing-Club-Portal" : "VDAN Ottenheim";
const resolvedAppThemeOverride = String(appThemeOverride || "").trim();
const effectiveAppTheme = resolvedAppThemeOverride || (isFcpMode
  ? (APP.theme === "fcp_brand" && isAppPath ? "fcp_tactical" : (APP.theme || "fcp_tactical"))
  : "vdan_default");
const themeColor = isFcpMode ? "#2f352a" : "#0b1220";
const normalizedTitle = String(title || runtimeSiteName).replace(APP.name, runtimeSiteName);
const displayTitle = isBetaChannel && !String(title).toLowerCase().includes("beta")
  ? `${normalizedTitle} · BETA`
  : normalizedTitle;
const host = Astro.url.hostname.toLowerCase();
const isFcpSchema =
  isFcpMode ||
  APP.brand.toLowerCase().includes("fcp") ||
  host.includes("fishing-club-portal.de");
const defaultSiteUrl = envText(
  import.meta.env.PUBLIC_SITE_URL,
  isFcpSchema ? "https://www.fishing-club-portal.de/" : "https://www.vdan-ottenheim.com/",
);
const canonical = canonicalProp || new URL(Astro.url.pathname, defaultSiteUrl).href;
const schemaBaseUrl = new URL(defaultSiteUrl).origin;
const schemaOrganization = {
  "@type": "Organization",
  "@id": `${schemaBaseUrl}#organization`,
  name: isFcpSchema
    ? "Fishing-Club-Portal"
    : "VDAN (Verein der Angler und Naturfreunde Ottenheim 1957 e.V.)",
  url: isFcpSchema ? "https://www.fishing-club-portal.de/" : "https://www.vdan-ottenheim.com/",
  email: APP.supportEmail,
};
const schemaWebsite = {
  "@type": "WebSite",
  "@id": `${schemaBaseUrl}#website`,
  url: schemaBaseUrl,
  name: runtimeSiteName,
  publisher: {
    "@id": `${schemaBaseUrl}#organization`,
  },
};
const schemaWebPage = {
  "@type": "WebPage",
  "@id": `${canonical}#webpage`,
  url: canonical,
  name: displayTitle,
  description,
  isPartOf: {
    "@id": `${schemaBaseUrl}#website`,
  },
};
const schemaGraphJson = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [schemaOrganization, schemaWebsite, schemaWebPage],
});
const manifestPath = isFcpMode ? "/manifest-fcp.webmanifest" : "/manifest-vdan.webmanifest";
const favicon16 = isFcpMode ? "/Branding/FCPIcons/favicon-16.png" : "/Bilder/logo180x180.png";
const favicon32 = isFcpMode ? "/Branding/FCPIcons/favicon-32.png" : "/Bilder/logo192x192.png";
const favicon192 = isFcpMode ? "/Branding/FCPIcons/icon-192.png" : "/Bilder/logo192x192.png";
const favicon512 = isFcpMode ? "/Branding/FCPIcons/icon-512.png" : "/Bilder/logo512x512.png";
const appleTouch = isFcpMode ? "/Branding/FCPIcons/apple-touch-icon.png" : "/Bilder/logo180x180.png";
const fcpHeaderLogoSvg = `/Branding/NewLogoCamouFCP.svg?v=${assetVersion}`;
const fcpHeaderLogoPng = `/Branding/NewLogoCamouFCP.png?v=${assetVersion}`;

// Guard member area paths:
const isScannerPath = path.startsWith("/app/ausweis/verifizieren/");
const isTermsPath = path === "/nutzungsbedingungen.html/" || path === "/nutzungsbedingungen.html";
const showPortalTermsLink = isAppPath || isTermsPath;
const needsMemberGuard = (isAppPath && !isScannerPath) || isTermsPath;
const showHeaderAuthCta = !isFcpMode;
const robotsMeta = staticPageBlocked
  ? "noindex,nofollow"
  : String(robots || "index").includes(",")
    ? String(robots)
    : `${robots},follow`;
const publicMenuLinks = isFcpMode
  ? [
      { href: "/", label: "Start" },
      { href: "/kontakt.html/", label: "Kontakt" },
      { href: "/datenschutz.html/", label: "Datenschutz" },
      { href: "/nutzungsbedingungen.html/", label: "Nutzungsbedingungen" },
      { href: "/impressum.html/", label: "Impressum" },
    ]
  : [
      { href: "/", label: "Start" },
      { href: "/termine.html/", label: "Termine" },
      { href: "/vdan-jugend.html/", label: "Jugend" },
      { href: "/mitglied-werden.html/", label: "Mitglied werden" },
      { href: "/fischereipruefung.html/", label: "Fischereiprüfung" },
      { href: "/anglerheim-ottenheim.html/", label: "Anglerheim" },
      { href: "/downloads.html/", label: "Downloads" },
      { href: "/vereinsshop.html/", label: "Vereinsshop" },
      { href: "/kontakt.html/", label: "Kontakt" },
      { href: "/datenschutz.html/", label: "Datenschutz" },
      { href: "/impressum.html/", label: "Impressum" },
    ];
---

<!doctype html>
<html lang="de" data-density={density}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{displayTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content={robotsMeta} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content={themeColor} />
    <link rel="manifest" href={manifestPath} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={runtimeSiteName} />
    <script type="application/ld+json" set:html={schemaGraphJson}></script>
    <link rel="icon" type="image/png" sizes="16x16" href={favicon16} />
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32} />
    <link rel="icon" type="image/png" sizes="192x192" href={favicon192} />
    <link rel="icon" type="image/png" sizes="512x512" href={favicon512} />
    <link rel="shortcut icon" type="image/png" href={favicon32} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouch} />
    <link rel="stylesheet" href="/css/ui-standards.css" />
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/consent-manager.css" />
    <slot name="head" />
  </head>
  <body
    data-supabase-url={supabaseUrl}
    data-supabase-key={supabaseKey}
    data-member-card-verify-pubkey={memberCardVerifyPubKey}
    data-vapid-public-key={vapidPublicKey}
    data-auth-email-change-enabled={authEmailChangeEnabled ? "1" : "0"}
    data-open-self-registration-enabled={openSelfRegistrationEnabled ? "1" : "0"}
    data-auth-allow-legacy-member-login={authAllowLegacyMemberLogin ? "1" : "0"}
    data-app-version={appVersion}
    data-app-channel={appChannel}
    data-app-theme={effectiveAppTheme}
    data-site-mode={resolvedSiteMode}
    data-static-web-route={staticPageEntry?.route || ""}
    data-static-web-brand={staticPageInitialBrand}
    data-superadmin-user-ids={APP.superAdminUserIds.join(",")}
  >
    <header class="header">
      <div class="container">
        <nav class="nav" aria-label="Hauptnavigation">
          <div
            id="headerBrandFcp"
            class={`header-brand-fcp${isFcpMode ? "" : " hidden"}`}
            aria-label="FCP Marke"
            hidden={!isFcpMode}
            data-brand-block="fcp"
          >
            <a class="logo" href="/" aria-label={APP.name}>
              <picture class="header-brand-fcp__logo" aria-hidden="true">
                <source srcset={fcpHeaderLogoSvg} type="image/svg+xml" />
                <img src={fcpHeaderLogoPng} alt="" loading="eager" decoding="async" />
              </picture>
            </a>
            {isBetaChannel && <span class="app-beta-badge header-brand-fcp__badge" aria-label={`Beta-Version ${appVersion}`}>BETA</span>}
          </div>
          <div
            id="headerBrandVdan"
            class={`header-brand-vdan${isFcpMode ? " hidden" : ""}`}
            hidden={isFcpMode}
            data-brand-block="vdan"
          >
            <a class="logo" href="/" aria-label={APP.name}>
              <img src="/Bilder/logo300x300.png" alt={APP.name} />
            </a>
            {isBetaChannel && <span class="app-beta-badge header-brand-fcp__badge" aria-label={`Beta-Version ${appVersion}`}>BETA</span>}
          </div>
          <div class="header-utility">
            {isFcpMode && (
              <div id="headerLoginEntryWrap" class="header-login-entry" data-ui-session-skip>
                <button
                  type="button"
                  id="headerLoginEntryToggle"
                  class="header-login-toggle"
                  aria-label="Login öffnen"
                  aria-expanded="false"
                  data-ui-session-skip
                >
                  Login
                </button>
                <div id="headerLoginEntryPopover" class="header-login-popover hidden" hidden data-ui-session-skip>
                  <div class="header-login-popover__section">
                    <h3>Anmelden</h3>
                    <form id="headerQuickLoginForm" class="header-login-form">
                      <label>
                        <span>E-Mail</span>
                        <input id="headerQuickLoginIdentifier" type="text" autocomplete="username" placeholder="name@beispiel.de" />
                      </label>
                      <label>
                        <span>Passwort</span>
                        <input id="headerQuickLoginPassword" type="password" autocomplete="current-password" placeholder="Passwort" />
                      </label>
                      <div class="header-login-form__actions">
                        <button type="submit" class="feed-btn">Login</button>
                        <a class="feed-btn feed-btn--ghost" href="/login/">Zur Login-Seite</a>
                      </div>
                      <p class="small"><a href="/passwort-vergessen/">Passwort vergessen?</a></p>
                      <p id="headerQuickLoginMsg" class="small" aria-live="polite"></p>
                    </form>
                  </div>
                </div>
              </div>
            )}
            <div id="headerNotificationWrap" class="header-notification-wrap hidden" hidden data-ui-session-skip>
              <button
                type="button"
                id="headerNotificationToggle"
                class="header-notification-toggle"
                aria-label="Benachrichtigungen öffnen"
                aria-expanded="false"
                data-ui-session-skip
              >
                <span aria-hidden="true">🔔</span>
                <span id="headerNotificationBadge" class="header-notification-badge hidden" hidden aria-hidden="true"></span>
              </button>
            </div>
            <div class="nav-actions header-menu">
              <span id="netStatusBadge" class="small hidden" hidden>Offline</span>
              {showHeaderAuthCta && <a id="headerAuthCta" class="header-auth-cta" href="/login/" data-ui-session-skip>Sign in</a>}
              <div class="burger-menu" id="burgerMenu">
                <button type="button" id="burgerToggle" class="burger-toggle" aria-label="Menü">
                  <span>☰</span>
                </button>
                <div id="burgerPopover" class="burger-popover hidden" hidden data-runtime-menu-scope={isFcpMode ? "fcp" : "vdan"}>
                  {publicMenuLinks.map((link) => (
                    (link.label === "Nutzungsbedingungen" && !showPortalTermsLink)
                      ? null
                      : <a href={link.href}>{link.label}</a>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </nav>
      </div>
    </header>
    <div id="memberNotificationsDrawer" class="member-notifications-drawer hidden" hidden data-ui-session-skip>
      <section id="memberNotificationsPanel" class="member-notifications-panel" aria-label="Benachrichtigungen">
        <div class="member-notifications-panel__head">
          <h2>Benachrichtigungen</h2>
          <div class="member-notifications-panel__actions">
            <button type="button" id="memberNotificationsMarkAll" class="member-notifications-mark-all">Alle gelesen</button>
            <button type="button" id="memberNotificationsClose" class="member-notifications-close" aria-label="Benachrichtigungen schließen">✕</button>
          </div>
        </div>
        <p class="small">Relevante Hinweise zu deinen Einsätzen und Freigaben.</p>
        <div id="memberNotificationsList" class="member-notifications-list"></div>
      </section>
    </div>
    <button
      type="button"
      id="portalQuickToggle"
      class="portal-quick-toggle"
      data-ui-session-skip
      aria-label="Portal öffnen"
    >
      <span aria-hidden="true">⌂</span>
      <span id="portalQuickUserBadge" class="portal-quick-user-badge hidden" hidden aria-hidden="true"></span>
    </button>
    <aside id="portalRail" class="portal-rail hidden" hidden data-ui-session-skip aria-label="Portal-Kurzmenü">
      <div id="portalRailItems" class="portal-rail__items"></div>
    </aside>
    <div id="portalQuickDrawer" class="portal-quick-drawer hidden" hidden data-ui-session-skip>
      <section id="portalQuickPanel" class="portal-quick-panel" aria-label="Portal Kurzmenü">
        <div class="portal-quick-panel__head">
          <h2>Fishing-Club-Portal</h2>
          <button type="button" id="portalQuickClose" class="portal-quick-close" aria-label="Portal schließen">✕</button>
        </div>
        <p class="small">Schnellzugriff für deine Favoriten.</p>
        <div id="portalQuickList" class="portal-quick-list"></div>
      </section>
    </div>
    <section id="goFishingDialog" class="catch-dialog catch-dialog--panel portal-gofishing-brand--fcp hidden" data-guard-sheet="1" data-guard-no-draft="1" hidden>
      <form id="goFishingDialogForm" class="catch-dialog__form portal-gofishing-dialog__form">
        <input type="hidden" id="goFishingDraftState" name="goFishingDraftState" value="" />
        <div class="portal-gofishing-dialog__content">
          <div class="portal-gofishing-hero">
            <div class="portal-gofishing-logo-wrap">
              <picture class="portal-quick-logo-slot__picture portal-gofishing-logo" aria-hidden="true">
                <source srcset="/Branding/New_FCP_GoFishing.svg" type="image/svg+xml" />
                <img class="portal-quick-logo-slot__img" src="/Branding/New_FCP_GoFishing.svg" alt="GoFishing FCP" loading="eager" decoding="async" />
              </picture>
              {isBetaChannel && <span class="app-beta-badge portal-gofishing-beta" aria-label={`Beta-Version ${appVersion}`}>BETA</span>}
              {!isBetaChannel && <span class="app-beta-badge portal-gofishing-beta" aria-hidden="true">BETA</span>}
            </div>
            <p class="small portal-gofishing-start" id="goFishingSessionStartLabel" aria-live="polite">Session noch nicht gestartet.</p>
          </div>

          <div class="portal-gofishing-fields">
            <div class="fangliste-form-grid portal-gofishing-form-grid">
              <label class="fangliste-full">
                <span>Gewässerquelle</span>
                <select id="goFishingWaterMode" aria-label="Gewässerquelle">
                  <option value="official" selected>Vereinsgewässer</option>
                  <option value="member">Freies Gewässer</option>
                </select>
              </label>
              <label class="fangliste-full">
                <span>Vereinsgewässer suchen</span>
                <input id="goFishingWaterSearch" type="search" placeholder="Gewässer filtern..." />
              </label>
              <label class="fangliste-full">
                <span>Vereinsgewässer</span>
                <select id="goFishingWater" required></select>
              </label>
              <div class="fangliste-full fangliste-water-favorites">
                <p id="goFishingWaterQuickTitle" class="small">Meistgenutzt</p>
                <div id="goFishingWaterFavorites" class="fangliste-water-chip-list" role="group" aria-label="Meistgenutzte Gewässer"></div>
              </div>
              <label class="fangliste-full hidden" id="goFishingMemberWaterNameWrap" hidden>
                <span>Freies Gewässername</span>
                <input id="goFishingMemberWaterName" type="text" placeholder="z. B. Baggersee Nord" maxlength="120" />
              </label>
              <label class="fangliste-full hidden" id="goFishingMemberWaterLocationWrap" hidden>
                <span>Ort / Abschnitt (optional)</span>
                <input id="goFishingMemberWaterLocation" type="text" placeholder="z. B. Lahr, Nordufer" maxlength="160" />
              </label>
              <label>
                <span>Zielfisch hinzufügen</span>
                <select id="goFishingFishSelect"></select>
              </label>
              <div class="portal-gofishing-add-wrap">
                <button type="button" id="goFishingAddFishBtn" class="feed-btn feed-btn--ghost">Hinzufügen</button>
              </div>
            </div>
            <div id="goFishingTargetList" class="portal-gofishing-target-list" role="group" aria-label="Zielfische Counter"></div>
            <p id="goFishingMsg" class="small portal-gofishing-msg" aria-live="polite"></p>
            <div class="catch-dialog__actions portal-gofishing-actions">
              <button type="button" class="feed-btn" id="goFishingStartBtn">Start</button>
              <button type="button" class="feed-btn" id="goFishingEndBtn">Session beenden</button>
              <button type="button" class="feed-btn feed-btn--ghost" data-action="close-gofishing">Schließen</button>
            </div>
          </div>
        </div>
      </form>
    </section>

    <main class="main">
      <div class={containerClass}>
        {staticPageVisible ? (
          <slot />
        ) : (
          <section class="card" style="max-width:840px;margin:0 auto;">
            <div class="card__body">
              <h1>Diese Seite ist in diesem Deploy nicht freigegeben.</h1>
              <p>
                Die statische Seite <strong>{staticPageEntry?.label || path}</strong> ist fuer das Ziel <strong>{resolvedSiteMode.toUpperCase()}</strong>
                aktuell auf <strong>nicht sichtbar</strong> gesetzt.
              </p>
              <p class="small">
                Antwortstatus: <strong>404</strong>. So bleibt die Trennung zwischen VDAN-Spezialseiten und FCP-Seiten sauber, nicht indexierbar und pruefbar.
              </p>
            </div>
          </section>
        )}
      </div>
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <p id="siteFooterTextFcp" class={`small${isFcpMode ? "" : " hidden"}`} hidden={!isFcpMode} data-brand-block="fcp">
          © Fishing-Club-Portal<br />
          Plattform: Fishing-Club-Portal - Software von Michael Lauenroth
        </p>
        <p id="siteFooterTextVdan" class={`small${isFcpMode ? " hidden" : ""}`} hidden={isFcpMode} data-brand-block="vdan">
          © VDAN Ottenheim<br />
          Website des VDAN Ottenheim mit angeschlossenem Mitgliederportal
        </p>
        <nav
          id="siteFooterLinksVdan"
          class={`site-footer__links${isFcpMode ? " hidden" : ""}`}
          aria-label="Rechtliche Links"
          hidden={isFcpMode}
          data-brand-block="vdan"
        >
            <a href="/kontakt.html/">Kontakt</a>
            <a href="/datenschutz.html/">Datenschutz</a>
            {showPortalTermsLink && <a href="/nutzungsbedingungen.html/">Nutzungsbedingungen</a>}
            <a href="/impressum.html/">Impressum</a>
            <a href="#" data-open-consent-settings>Datenschutz-Einstellungen</a>
        </nav>
      </div>
    </footer>

    <script is:inline src="/js/runtime-guard.js"></script>
    <script src="/js/app-env.js" defer></script>
    <script src="/js/offline-data-store.js" defer></script>
    <script src="/js/offline-sync.js" defer></script>
    <script src="/js/consent-manager.js" defer></script>
    <script src="/js/member-auth.js" defer></script>
    {isAppPath && <script src="/js/app-brand-runtime.js" defer></script>}
    {!isAppPath && <script src="/js/static-web-runtime.js" defer></script>}
    <script src="/js/ui-standards-runtime.js" defer></script>
    {needsMemberGuard && <script src="/js/member-guard.js" defer></script>}
    <script src="/js/ui-session.js" defer></script>
    <script src="/js/header-auth-cta.js" defer></script>
    <script src="/js/header-login-entry.js" defer></script>
    <script src="/js/header-brand-scroll.js" defer></script>
    <script src="/js/notifications-center.js" defer></script>
    <script src="/js/nav-burger.js" defer></script>
    <script src="/js/portal-quick.js" defer></script>
    <script src="/js/studio-inspector-bridge.js" defer></script>
    <script src="/js/go-fishing.js" defer></script>
    <script src="/js/dialog-ux-guard.js" defer></script>
    <script src="/js/pwa-register.js" defer></script>
    <!-- <script src="/js/maintenance-gate.js" defer></script> -->
  </body>
</html>
