---
import Site from "../../../layouts/Site.astro";
import { APP } from "../../../config/app";
import { STATIC_WEB_ENV_HINTS, STATIC_WEB_PAGES } from "../../../config/static-web-pages";
import { APP_MASK_BRAND_PAGES } from "../../../config/app-mask-brand-pages";
---

<Site
  title={`Admin Board • ${APP.name}`}
  description="Zentrales Admin-Board für Onboarding, Auth und Plattform-Überblick"
  robots="noindex"
  containerClass="container container--admin-wide"
>
  <section class="card">
    <div class="card__body">
      <h1>Admin Board</h1>
      <p class="small">P0 Steuerzentrale für Onboarding/Auth/Übersicht vor dem großen Umbau.</p>
      <p id="adminBoardMsg" class="small" aria-live="polite"></p>
    </div>
  </section>

  <section class="card">
    <div class="card__body admin-board">
      <aside class="admin-board__nav" aria-label="Admin Navigation">
        <button type="button" class="admin-nav-btn is-active" data-admin-section="dashboard">Dashboard</button>
        <button type="button" class="admin-nav-btn" data-admin-section="clubs">Clubs</button>
        <button type="button" class="admin-nav-btn" data-admin-section="members">Mitglieder</button>
        <button type="button" class="admin-nav-btn" data-admin-section="analytics">Analytics</button>
        <button type="button" class="admin-nav-btn" data-admin-section="bugs">Bugs</button>
        <button type="button" class="admin-nav-btn" data-admin-section="finance">Finanzen</button>
        <button type="button" class="admin-nav-btn" data-admin-section="dsgvo">DSGVO</button>
        <button type="button" class="admin-nav-btn" data-admin-section="security">Security</button>
        <button type="button" class="admin-nav-btn" data-admin-section="modules">Module</button>
        <button type="button" class="admin-nav-btn" data-admin-section="webmodules">Modul Web</button>
      </aside>

      <div class="admin-board__content">
        <section class="admin-section is-active" data-admin-panel="dashboard">
          <article class="admin-card">
            <h2>Dashboard</h2>
            <div class="admin-kpi-grid">
              <article class="admin-kpi"><h3>Vereine gesamt</h3><p id="kpiClubs">-</p></article>
              <article class="admin-kpi"><h3>Mitglieder aktiv</h3><p id="kpiMembersActive">-</p></article>
              <article class="admin-kpi"><h3>Nie eingeloggt</h3><p id="kpiNeverLogin">-</p></article>
              <article class="admin-kpi"><h3>User ohne Verein</h3><p id="kpiUsersNoClub">-</p></article>
              <article class="admin-kpi"><h3>User mit Verein</h3><p id="kpiUsersWithClub">-</p></article>
            </div>
          </article>

          <article class="admin-card">
            <h3>Vereine (Top-Liste)</h3>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminClubsTopTable" data-studio-component-type="table" data-studio-library-id="lists--standard-tabelle" data-table-id="admin-clubs-top">
                <thead>
                  <tr>
                    <th>Verein</th><th>Mitglieder (Personen)</th><th>Rollen-Zuordnungen</th><th>Aktiv</th><th>Letzte Aktivität</th><th>Status</th><th>Club-ID</th>
                  </tr>
                </thead>
                <tbody><tr><td colspan="7" class="small">Lade Daten...</td></tr></tbody>
              </table>
            </div>
          </article>

          <article class="admin-card">
            <h3>User (zuletzt aktiv)</h3>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminUsersTopTable" data-studio-component-type="table" data-studio-library-id="lists--standard-tabelle" data-table-id="admin-users-top">
                <thead>
                  <tr>
                    <th>Name/Mail</th><th>User-ID</th><th>Letzter Login</th><th>Clubs</th><th>Status</th>
                  </tr>
                </thead>
                <tbody><tr><td colspan="5" class="small">Lade Daten...</td></tr></tbody>
              </table>
            </div>
          </article>
        </section>

        <section class="admin-section" data-admin-panel="clubs">
          <article class="admin-card">
            <h2>Clubs</h2>
            <div class="admin-actions">
              <a href="/app/vereine/" class="feed-btn">Neuen Club anlegen</a>
            </div>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminClubsTable" data-studio-component-type="table" data-studio-library-id="lists--standard-tabelle" data-table-id="admin-clubs">
                <thead>
                  <tr>
                    <th>Verein</th><th>Erstellt am</th><th>Mitglieder (Personen)</th><th>Rollen-Zuordnungen</th><th>Aktiv</th><th>Nie eingeloggt</th><th>Status</th><th>Aktionen</th><th>Club-ID</th>
                  </tr>
                </thead>
                <tbody><tr><td colspan="9" class="small">Lade Daten...</td></tr></tbody>
              </table>
            </div>
          </article>

          <article class="admin-card hidden" hidden id="adminClubDetailCard">
            <div class="admin-card-toolbar">
              <div class="admin-card-toolbar__meta">
                <h3 id="adminClubDetailTitle">Club-Detail</h3>
                <p class="small" id="adminClubDetailMeta">-</p>
                <p class="small" id="adminClubDetailMsg" aria-live="polite"></p>
              </div>
              <div class="admin-actions admin-actions--toolbar">
                <button type="button" class="feed-btn feed-btn--ghost" id="adminClubDetailSave">Modulzusammensetzung speichern</button>
                <button type="button" class="feed-btn feed-btn--ghost" id="adminClubDetailReset">Standard für Club laden</button>
                <button type="button" class="feed-btn feed-btn--ghost" id="adminClubDetailClose">Schließen</button>
              </div>
            </div>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminClubModulesTable" data-studio-component-type="table" data-studio-library-id="lists--standard-tabelle" data-table-id="admin-club-modules">
                <thead>
                  <tr>
                    <th>Modul</th><th>Aktiv</th><th>Usecases</th><th>Hinweis</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </article>
        </section>

        <section class="admin-section" data-admin-panel="members">
          <article class="admin-card">
            <h2>Mitglieder</h2>
            <div class="admin-filter-row">
              <input id="adminMemberSearch" type="search" placeholder="Suche Name, Mail, User-ID..." />
              <select id="adminMemberFilter">
                <option value="all">Alle</option>
                <option value="no_club">Ohne Verein</option>
                <option value="with_club">Mit Verein</option>
                <option value="never_login">Nie eingeloggt</option>
              </select>
            </div>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminMembersTable" data-studio-component-type="table" data-studio-library-id="lists--standard-tabelle" data-table-id="admin-members">
                <thead>
                  <tr>
                    <th>Name</th><th>E-Mail</th><th>User-ID</th><th>Letzter Login</th><th>Nie eingeloggt</th><th>Clubs</th><th>Status</th><th>Aktionen</th>
                  </tr>
                </thead>
                <tbody><tr><td colspan="8" class="small">Lade Daten...</td></tr></tbody>
              </table>
            </div>
          </article>
        </section>

        <section class="admin-section" data-admin-panel="analytics">
          <article class="admin-card">
            <h2>Analytics</h2>
            <p class="small">Governance-Monitoring aus zentralem Snapshot (Source of Truth für Board + Nightly + CI).</p>
            <div class="admin-kpi-grid">
              <article class="admin-kpi"><h3>Clubs gruen</h3><p id="kpiGovGreen">-</p></article>
              <article class="admin-kpi"><h3>Clubs gelb</h3><p id="kpiGovYellow">-</p></article>
              <article class="admin-kpi"><h3>Clubs rot</h3><p id="kpiGovRed">-</p></article>
              <article class="admin-kpi"><h3>Issues gesamt</h3><p id="kpiGovIssues">-</p></article>
              <article class="admin-kpi"><h3>Offene Rules</h3><p id="kpiGovRulesOpen">-</p></article>
            </div>
            <p class="small" id="adminGovernanceMsg" aria-live="polite"></p>
          </article>

          <article class="admin-card">
            <h3>Governance-Health je Club</h3>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminGovernanceHealthTable" data-studio-component-type="table" data-studio-library-id="lists--standard-tabelle" data-table-id="admin-governance-health">
                <thead>
                  <tr>
                    <th>Verein</th>
                    <th>Status</th>
                    <th>Issues</th>
                    <th>Identity Gaps</th>
                    <th>Roles ohne Membership</th>
                    <th>Doppelte Identities</th>
                    <th>Members ohne Identity-Link</th>
                    <th>Name/Code fehlt</th>
                    <th>Club-ID</th>
                  </tr>
                </thead>
                <tbody><tr><td colspan="9" class="small">Lade Daten...</td></tr></tbody>
              </table>
            </div>
          </article>

          <article class="admin-card">
            <h3>Governance-Issues (Drilldown)</h3>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminGovernanceIssuesTable" data-studio-component-type="table" data-studio-library-id="lists--standard-tabelle" data-table-id="admin-governance-issues">
                <thead>
                  <tr>
                    <th>Rule</th>
                    <th>Verein</th>
                    <th>Ref-1</th>
                    <th>Ref-2</th>
                    <th>Detail</th>
                  </tr>
                </thead>
                <tbody><tr><td colspan="5" class="small">Lade Daten...</td></tr></tbody>
              </table>
            </div>
          </article>
        </section>

        <section class="admin-section" data-admin-panel="bugs">
          <article class="admin-card is-missing">
            <span class="admin-missing-badge" aria-label="Noch nicht gebaut">✖</span>
            <h2>Bugs</h2>
            <p class="small">Bug-Board mit P0/P1/P2, Owner und Referenzen wird hier zentral aggregiert.</p>
          </article>
        </section>

        <section class="admin-section" data-admin-panel="finance">
          <article class="admin-card is-missing">
            <span class="admin-missing-badge" aria-label="Noch nicht gebaut">✖</span>
            <h2>Finanzen</h2>
            <p class="small">Einnahmen/Entitlements/Export als spätere Billing-Ausbaustufe.</p>
          </article>
        </section>

        <section class="admin-section" data-admin-panel="dsgvo">
          <article class="admin-card is-missing">
            <span class="admin-missing-badge" aria-label="Noch nicht gebaut">✖</span>
            <h2>DSGVO Board</h2>
            <ul class="small">
              <li>Verantwortlicher / Kontakt</li>
              <li>Zwecke / Datenkategorien</li>
              <li>Auftragsverarbeiter / Subprozessoren</li>
              <li>Speicherfristen / Betroffenenrechte / Consent</li>
            </ul>
          </article>
        </section>

        <section class="admin-section" data-admin-panel="security">
          <article class="admin-card is-missing">
            <span class="admin-missing-badge" aria-label="Noch nicht gebaut">✖</span>
            <h2>Security Board</h2>
            <ul class="small">
              <li>Auth-Konzept / Rollenmodell</li>
              <li>RLS-Status je Domaintabelle</li>
              <li>Secrets/Rotation/Runbook</li>
              <li>Audit-Logging / Backup & Restore</li>
            </ul>
          </article>
        </section>

        <section class="admin-section" data-admin-panel="modules">
          <article class="admin-card">
            <h2>Module (Portal)</h2>
            <div class="admin-actions">
              <button type="button" class="feed-btn feed-btn--ghost" id="adminRoleMatrixSavePortal">Portal speichern</button>
              <button type="button" class="feed-btn feed-btn--ghost" id="adminRoleMatrixResetPortal">Portal reset</button>
              <button type="button" class="feed-btn feed-btn--ghost" id="adminRoleMatrixCopyPortal">Portal JSON</button>
            </div>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminModulesTable" data-studio-component-type="table" data-studio-library-id="lists--standard-tabelle" data-table-id="admin-modules">
                <thead>
                  <tr>
                    <th>Seite</th><th>Route</th><th>Typ</th><th>Guest</th><th>Member</th><th>Manager</th><th>Admin</th><th>Superadmin</th><th>Aktion</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </article>

          <article class="admin-card">
            <h3>Modul-Katalog (Superadmin)</h3>
            <p class="small">Hier definierst du Modulpakete und welche Usecases jeweils enthalten sind.</p>
            <p class="small" id="adminModuleCatalogMsg" aria-live="polite"></p>
            <div class="admin-actions">
              <button type="button" class="feed-btn feed-btn--ghost" id="adminModuleCatalogSave">Katalog speichern</button>
              <button type="button" class="feed-btn feed-btn--ghost" id="adminModuleCatalogReset">Katalog reset</button>
            </div>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminModuleCatalogTable" data-studio-component-type="table" data-studio-library-id="lists--standard-tabelle" data-table-id="admin-module-catalog">
                <thead>
                  <tr>
                    <th>Modul-Key</th><th>Label</th><th>Usecases (kommagetrennt)</th><th>Aktiv</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </article>

          <article class="admin-card">
            <h3>Standard-Rollenrechte (Superadmin)</h3>
            <p class="small">Diese Defaults gelten für Vereine und können dort nur innerhalb freigegebener Module feinjustiert werden.</p>
            <p class="small" id="adminRoleDefaultsMsg" aria-live="polite"></p>
            <div class="admin-actions">
              <label class="small" style="display:flex;align-items:center;gap:8px;">
                Rolle
                <select id="adminRoleDefaultsRole">
                  <option value="member">member</option>
                  <option value="vorstand">vorstand</option>
                  <option value="admin">admin</option>
                </select>
              </label>
              <button type="button" class="feed-btn feed-btn--ghost" id="adminRoleDefaultsSave">Defaults speichern</button>
              <button type="button" class="feed-btn feed-btn--ghost" id="adminRoleDefaultsReset">Defaults reset</button>
            </div>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminRoleDefaultsTable" data-studio-component-type="table" data-studio-library-id="lists--standard-tabelle" data-table-id="admin-role-defaults">
                <thead>
                  <tr>
                    <th>Modul</th><th>Usecase</th><th>Anzeigen</th><th>Lesen</th><th>Schreiben</th><th>Bearbeiten</th><th>Löschen</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </article>
        </section>

        <section class="admin-section" data-admin-panel="webmodules">
          <article class="admin-card">
            <h2>Modul Web (Burger-Menü)</h2>
            <div class="admin-actions">
              <button type="button" class="feed-btn feed-btn--ghost" id="adminRoleMatrixSaveWeb">Web speichern</button>
              <button type="button" class="feed-btn feed-btn--ghost" id="adminRoleMatrixResetWeb">Web reset</button>
              <button type="button" class="feed-btn feed-btn--ghost" id="adminRoleMatrixCopyWeb">Web JSON</button>
            </div>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminWebModulesTable" data-studio-component-type="table" data-studio-library-id="lists--standard-tabelle" data-table-id="admin-web-modules">
                <thead>
                  <tr>
                    <th>Seite</th><th>Route</th><th>Typ</th><th>Guest</th><th>Member</th><th>Manager</th><th>Admin</th><th>Superadmin</th><th>Aktion</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </article>

          <article class="admin-card">
            <h3>Statische Seiten nach Deploy-Ziel</h3>
            <p class="small">
              Die harte Guard-Grenze bleibt im Code. Sichtbarkeit und Brand der freigegebenen statischen Seiten koennen hier live als
              Runtime-Ausblendung bzw. Brand-Umschaltung aus der DB gesteuert werden.
            </p>
            <p class="small" id="adminStaticWebMsg" aria-live="polite"></p>
            <div class="admin-actions">
              <button type="button" class="feed-btn feed-btn--ghost" id="adminStaticWebSave">Web-Plan speichern</button>
              <button type="button" class="feed-btn feed-btn--ghost" id="adminStaticWebReset">Web-Draft reset</button>
              <button type="button" class="feed-btn feed-btn--ghost" id="adminStaticWebCopy">Web-JSON</button>
            </div>

            <details class="template-accordion" id="adminStaticWebFcpAccordion">
              <summary>FCP</summary>
              <div class="work-part-table-wrap">
                <table class="work-part-table" id="adminStaticPagesFcpTable">
                  <thead>
                    <tr>
                      <th>Seite</th><th>Route</th><th>Sichtbar</th><th>VDAN Brand</th><th>FCP Brand</th><th>Hinweis</th>
                    </tr>
                  </thead>
                  <tbody></tbody>
                </table>
              </div>
            </details>

            <details class="template-accordion" id="adminStaticWebVdanAccordion">
              <summary>VDAN</summary>
              <div class="work-part-table-wrap">
                <table class="work-part-table" id="adminStaticPagesVdanTable">
                  <thead>
                    <tr>
                      <th>Seite</th><th>Route</th><th>Sichtbar</th><th>VDAN Brand</th><th>FCP Brand</th><th>Hinweis</th>
                    </tr>
                  </thead>
                  <tbody></tbody>
                </table>
              </div>
            </details>
          </article>

          <article class="admin-card">
            <h3>App-Masken Brand-Overrides</h3>
            <p class="small">
              Diese Overrides wirken live auf die App-Masken. Damit kannst du Farben und Brand-Switches unterwegs umstellen, ohne die statischen VDAN-Seiten anzutasten.
            </p>
            <p class="small" id="adminAppMaskBrandMsg" aria-live="polite"></p>
            <div class="admin-actions">
              <button type="button" class="feed-btn feed-btn--ghost" id="adminAppMaskBrandSave">Masken-Brand speichern</button>
              <button type="button" class="feed-btn feed-btn--ghost" id="adminAppMaskBrandReset">Masken-Brand reset</button>
              <button type="button" class="feed-btn feed-btn--ghost" id="adminAppMaskBrandCopy">Masken-JSON</button>
            </div>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminAppMaskBrandTable">
                <thead>
                  <tr>
                    <th>Maske</th><th>Route</th><th>VDAN</th><th>FCP Tactical</th><th>FCP Brand</th><th>Hinweis</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </article>

          <article class="admin-card">
            <h3>Brand- und Env-Hinweise</h3>
            <p class="small">
              Diese Keys muessen pro Ziel sauber gesetzt sein. Die statischen Seiten bleiben davon getrennt steuerbar.
            </p>
            <div class="work-part-table-wrap">
              <table class="work-part-table" id="adminStaticEnvHintsTable">
                <thead>
                  <tr>
                    <th>Ziel</th><th>Key</th><th>Wert</th>
                  </tr>
                </thead>
                <tbody>
                  {Object.entries(STATIC_WEB_ENV_HINTS).flatMap(([target, hints]) =>
                    Object.entries(hints).map(([key, value]) => (
                      <tr>
                        <td>{target.toUpperCase()}</td>
                        <td><code>{key}</code></td>
                        <td><code>{value}</code></td>
                      </tr>
                    ))
                  )}
                </tbody>
              </table>
            </div>
          </article>
        </section>
      </div>
    </div>
  </section>

  <div
    id="adminStaticWebConfig"
    data-static-web-pages={JSON.stringify(STATIC_WEB_PAGES)}
    data-app-mask-brand-pages={JSON.stringify(APP_MASK_BRAND_PAGES)}
  ></div>

  <script src="/js/admin-board.js" defer></script>
</Site>
