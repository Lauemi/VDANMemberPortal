---
import Site from "../../../layouts/Site.astro";
import { APP } from "../../../config/app";
---

<Site title={`Termine / Events • ${APP.name}`} description="Gemeinsame Tabellenansicht für Termine und Arbeitseinsätze" robots="noindex">
  <section class="card" data-studio-component-id="events-overview-shell" data-studio-component-type="section" data-studio-slot="main">
    <div class="card__body" data-studio-component-id="events-overview-content" data-studio-component-type="section" data-studio-slot="main">
      <div class="catch-table-toolbar">
        <h1>Termine / Events</h1>
      </div>
      <p class="small">Gemeinsame Standardtabelle für Termine und Arbeitseinsätze. Fokus auf Suche, Filter und schnelle Übersicht.</p>

      <div class="ui-filter-row">
        <label>
          <span>Suche</span>
          <input id="eventsOverviewSearch" type="search" placeholder="Titel oder Ort durchsuchen" data-studio-component-id="events-overview-search" data-studio-component-type="input" data-studio-slot="main" />
        </label>
        <label>
          <span>Art</span>
          <select id="eventsOverviewTypeFilter" data-studio-component-id="events-overview-type-filter" data-studio-component-type="input" data-studio-slot="main">
            <option value="alle">Alle</option>
            <option value="termin">Termin</option>
            <option value="arbeitseinsatz">Arbeitseinsatz</option>
          </select>
        </label>
      </div>

      <p id="eventsOverviewMsg" class="small" aria-live="polite"></p>

      <div id="eventsOverviewTableWrap" class="catch-table" data-studio-component-id="events-overview-table" data-studio-component-type="table" data-studio-slot="main" data-studio-library-id="lists--standard-tabelle" data-table-id="events-overview">
        <div class="catch-table__head" style="grid-template-columns:1fr .9fr 1.6fr 1fr 1fr .8fr">
          <span>Datum</span>
          <span>Zeit</span>
          <span>Titel</span>
          <span>Art</span>
          <span>Ort</span>
          <span>Status</span>
        </div>
        <div id="eventsOverviewTableBody"></div>
      </div>
    </div>
  </section>

  <script src="/js/events-overview.js" defer></script>
</Site>
