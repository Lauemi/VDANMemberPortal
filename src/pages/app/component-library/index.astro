  robots="noindex"
  containerClass="container container--admin-wide"
>
  <section class="card">
    <div class="card__body lib-hero">
      <h1>Component Library</h1>
      <p class="small">
        Verbindliche interne Referenzmaske fur wiederverwendbare UI-Bausteine.
        Jede neue Maske soll sich an diesen Komponenten, Maßen und Interaktionsmustern orientieren.
      </p>
      <div class="lib-principles" role="list" aria-label="UX Leitlinien">
        <span class="lib-principle" role="listitem">Einhand-Bedienung zuerst</span>
        <span class="lib-principle" role="listitem">Klickbarkeit ist sofort erkennbar</span>
        <span class="lib-principle" role="listitem">Maße bleiben konsistent</span>
        <span class="lib-principle" role="listitem">Dialoge wirken aus einem Guss</span>
        <span class="lib-principle" role="listitem">Flow statt Seitensammlung</span>
      </div>
      <div class="lib-editor-controls">
        <button id="libSaveBtn" type="button" class="feed-btn">Standards lokal speichern</button>
        <button id="libExportBtn" type="button" class="feed-btn feed-btn--ghost">JSON exportieren</button>
        <button id="libImportBtn" type="button" class="feed-btn feed-btn--ghost">JSON importieren</button>
        <button id="libApplyButtonsBtn" type="button" class="feed-btn">Buttons appweit anwenden</button>
        <button id="libClearButtonsBtn" type="button" class="feed-btn feed-btn--ghost">Button-Override entfernen</button>
        <button id="libResetBtn" type="button" class="feed-btn feed-btn--ghost">Reset</button>
      </div>
      <p id="libEditorStatus" class="small" aria-live="polite">Editor bereit. Änderungen können lokal gespeichert und als JSON exportiert werden.</p>
      <label class="lib-export-row" for="libExportArea">
        <span class="small">Export / Import JSON (hier kopieren und mir senden)</span>
        <textarea id="libExportArea" rows={5} placeholder='{"version":"1.0","components":{...}}'></textarea>
      </label>
      <label class="lib-export-row" for="libSchemaArea">
        <span class="small">Generator-Schema (Auto, nur lesen)</span>
        <textarea id="libSchemaArea" rows={7} readonly></textarea>
      </label>
    </div>
  </section>

  <section class="card">
    <div class="card__body">
      <h2>Globale Tokens & Layers</h2>
      <div class="lib-token-grid">
        <article class="lib-token-card">
          <h3>Farben</h3>
          <p class="small"><code>--bg: #0B1220</code> · <code>--panel: #111A2C</code> · <code>--text: #E8EAF0</code> · <code>--line: #2A3550</code> · <code>--brand: #6C705B</code></p>
        </article>
        <article class="lib-token-card">
          <h3>Spacing</h3>
          <p class="small"><code>--space-1: 8px</code> · <code>--space-2: 16px</code> · <code>--space-3: 24px</code> · <code>--space-4: 32px</code></p>
        </article>
        <article class="lib-token-card">
          <h3>Radius</h3>
          <p class="small"><code>--radius-md: 12px</code> · Sheet/Confirm: <code>14px</code> bei Bedarf</p>
        </article>
        <article class="lib-token-card">
          <h3>Typo</h3>
          <p class="small">Body <code>16px</code> · Table <code>14px</code> · Secondary <code>14px</code></p>
        </article>
        <article class="lib-token-card">
          <h3>Icons & Touch</h3>
          <p class="small">Icon Standard <code>24px</code> · Minimum Touch-Target <code>48x48px</code></p>
        </article>
        <article class="lib-token-card">
          <h3>Dialog-Breiten</h3>
          <p class="small">Desktop <code>min(92vw, 560px)</code> · Tablet <code>min(88vw, 500px)</code> · Mobile <code>100vw</code></p>
        </article>
        <article class="lib-token-card">
          <h3>Z-Index Layer</h3>
          <p class="small">Header <code>1200</code> · Popover <code>1300</code> · Portal Quick <code>1490-1511</code> · Dialog <code>3000</code></p>
        </article>
      </div>
    </div>
  </section>

  {
    categories.map((category) => (
      <section id={category.id} class="card lib-category">
        <div class="card__body">
          <header class="lib-cat-head">
            <button
              type="button"
              class="lib-cat-toggle"
              data-category={category.id}
              aria-expanded={expandedState(category.id)}
              aria-controls={"panel-" + category.id}
            >
              <span class="lib-cat-toggle__title">{category.title}</span>
              <span class="lib-cat-toggle__meta">{category.items.length} Komponenten</span>
              <span class="lib-cat-toggle__icon" aria-hidden="true">▾</span>
            </button>
            <p class="small">{category.description}</p>
          </header>

          <div id={`panel-${category.id}`} class="lib-category-panel" hidden={category.id !== DEFAULT_OPEN_CATEGORY}>
            <div class="lib-component-grid">
              {
                category.items.map((item) => (
                  <article class="lib-component-card" data-component-key={`${category.id}--${toSlug(item.name)}`}>
                  <div class="lib-preview">
                    <div class="lib-status-wrap">
                      <span class={`lib-status ${statusClass(item.status)}`}>
                        {item.status}
                      </span>
                      <label class="lib-enable-toggle">
                        <input type="checkbox" class="lib-component-enabled" data-default="true" checked />
                        <span>Komponente aktiv</span>
                      </label>
                    </div>

                    {item.preview === "button" && (
                      <div class="lib-preview-block lib-preview-buttons">
                        {item.variant === "primary" && <button type="button" class="feed-btn">Primary Action</button>}
                        {item.variant === "secondary" && <button type="button" class="feed-btn feed-btn--ghost">Secondary Action</button>}
                        {item.variant === "ghost" && <button type="button" class="feed-btn feed-btn--ghost">Ghost Action</button>}
                        {item.variant === "icon" && <button type="button" class="burger-toggle" aria-label="Icon Button">☰</button>}
                        {item.variant === "danger" && <button type="button" class="lib-danger-btn">Delete</button>}
                      </div>
                    )}

                    {item.preview === "input" && (
                      <div class="lib-preview-block lib-preview-inputs">
                        {(item.variant === "text" || item.variant === "search") && (
                          <input type={inputPreview(item.variant).type} value={inputPreview(item.variant).value} aria-label={item.name} />
                        )}
                        {item.variant === "select" && (
                          <select aria-label={item.name}>
                            <option>Option A</option>
                            <option>Option B</option>
                          </select>
                        )}
                        {item.variant === "textarea" && <textarea rows={3} aria-label={item.name}>Mehrzeilige Eingabe</textarea>}
                        {item.variant === "checks" && (
                          <div class="lib-check-set">
                            <label class="small"><input type="checkbox" checked /> Checkbox</label>
                            <label class="small"><input type="radio" name="lib-radio" checked /> Radio</label>
                            <button type="button" class="toggle" aria-pressed="true"><span /></button>
                          </div>
                        )}
                      </div>
                    )}

                    {item.preview === "chip" && (
                      <div class="lib-preview-block lib-preview-chips">
                        {item.variant === "status" && (
                          <div class="lib-chip-set">
                            <span class="chip chip-success">Aktiv</span>
                            <span class="chip chip-warning">Prüfen</span>
                            <span class="chip chip-danger">Kritisch</span>
                          </div>
                        )}
                        {item.variant === "filter" && (
                          <div class="lib-chip-set">
                            <button type="button" class="fangliste-water-chip">Filter A</button>
                            <button type="button" class="fangliste-water-chip">Filter B</button>
                          </div>
                        )}
                        {item.variant === "info" && <span class="trip-filter-meta">3 Filter aktiv</span>}
                        {item.variant === "beta" && <span class="app-beta-badge">BETA</span>}
                      </div>
                    )}

                    {item.preview === "card" && (
                      <div class="lib-preview-block lib-preview-cards">
                        <article class="card">
                          <div class="card__body">
                            <h3>{item.name}</h3>
                            <p class="small">Kompakte Vorschau fur {item.type}.</p>
                            {item.variant === "action" && <button type="button" class="feed-btn feed-btn--ghost">Open</button>}
                          </div>
                        </article>
                      </div>
                    )}

                    {item.preview === "nav" && (
                      <div class="lib-preview-block lib-preview-nav">
                        {item.variant === "header" && (
                          <div class="lib-mock-header">
                            <span class="lib-mock-logo">VDAN</span>
                            <span class="lib-mock-logo lib-mock-logo--fcp">FCP</span>
                            <button type="button" class="burger-toggle" aria-label="Menu">☰</button>
                          </div>
                        )}
                        {item.variant === "burger" && <button type="button" class="burger-toggle" aria-label="Menu">☰</button>}
                        {item.variant === "tab" && (
                          <div class="ui-view-toggle" role="group" aria-label="Tab Preview">
                            <button type="button" class="feed-btn">Aktiv</button>
                            <button type="button" class="feed-btn feed-btn--ghost">Sekundär</button>
                          </div>
                        )}
                        {item.variant === "bottom" && (
                          <div class="lib-bottom-actions">
                            <button type="button" class="feed-btn">Action</button>
                            <button type="button" class="feed-btn feed-btn--ghost">More</button>
                          </div>
                        )}
                        {item.variant === "quick" && (
                          <div class="lib-quick-actions">
                            <button type="button" class="portal-quick-toggle" aria-label="Portal">⌂</button>
                            <div class="portal-rail__items">
                              <span class="portal-rail__item">A</span>
                              <span class="portal-rail__item">B</span>
                            </div>
                          </div>
                        )}
                      </div>
                    )}

                    {item.preview === "dialog" && (
                      <div class="lib-preview-block lib-preview-dialog">
                        <div class="lib-mock-dialog">
                          <h3>{item.name}</h3>
                          <p class="small">Dialog-Vorschau mit konsistenter Action-Zone.</p>
                          <div class="catch-dialog__actions">
                            <button type="button" class="feed-btn feed-btn--ghost">Cancel</button>
                            <button type="button" class="feed-btn">Confirm</button>
                          </div>
                        </div>
                      </div>
                    )}

                    {item.preview === "list" && (
                      <div class="lib-preview-block lib-preview-list">
                        {item.variant === "table" && (
                          <div class="catch-table lib-real-table lib-real-table--fit">
                            <div class="catch-table__head">
                              <span class="lib-col-head">Mitglied <span class="lib-col-filter" aria-hidden="true">⇅</span></span>
                              <span class="lib-col-head">Status <span class="lib-col-filter" aria-hidden="true">⇅</span></span>
                              <span class="lib-col-head">Datum <span class="lib-col-filter" aria-hidden="true">⇅</span></span>
                            </div>
                            <div class="catch-table__row">
                              <span>Max Mustermann</span>
                              <span class="chip chip-success">Aktiv</span>
                              <span>04.03.2026</span>
                            </div>
                            <div class="catch-table__row">
                              <span>Anna Beispiel</span>
                              <span class="chip chip-warning">Prüfen</span>
                              <span>05.03.2026</span>
                            </div>
                          </div>
                        )}
                        {item.variant === "toolbar" && (
                          <div class="trip-table-toolbar">
                            <div class="trip-table-search">
                              <input type="search" value="Mitglied suchen..." aria-label="Toolbar Suche" />
                            </div>
                            <div class="trip-table-toolbar__actions">
                              <span class="trip-filter-meta">2 Filter</span>
                              <button type="button" class="feed-btn feed-btn--ghost">Reset</button>
                            </div>
                          </div>
                        )}
                        {item.variant === "view-toggle" && (
                          <div class="ui-view-toggle" role="group" aria-label="Ansicht umschalten">
                            <button type="button" class="feed-btn">Tabelle</button>
                            <button type="button" class="feed-btn feed-btn--ghost">Karte</button>
                          </div>
                        )}
                        {(item.variant === "row" || item.variant === "card-item") && (
                          <>
                            {item.variant === "row" && (
                              <div class="catch-table lib-real-table lib-real-table--single">
                                <div class="catch-table__head">
                                  <span>Mitglied</span>
                                  <span>Status</span>
                                  <span>Datum</span>
                                </div>
                                <div class="catch-table__row">
                                  <span>Demo Mitglied</span>
                                  <span class="chip">Aktiv</span>
                                  <span>04.03.2026</span>
                                </div>
                              </div>
                            )}
                            {item.variant === "card-item" && (
                              <div class="lib-mock-list-row">
                                <span class="small">Demo Mitglied</span>
                                <span class="chip">Aktiv</span>
                                <span class="small">04.03.2026</span>
                              </div>
                            )}
                          </>
                        )}
                        {item.variant === "filterbar" && (
                          <div class="members-filter-panel lib-filter-demo">
                            <label class="small">Status</label>
                            <select aria-label="Filter Status">
                              <option>Alle</option>
                              <option>Aktiv</option>
                            </select>
                          </div>
                        )}
                      </div>
                    )}

                    {(functionsForItem(item).length > 0 || checksForItem(item).length > 0) && (
                      <section class="lib-functions" aria-label="Funktionen und Checks">
                        {functionsForItem(item).length > 0 && (
                          <>
                            <h4>Funktionen / Verhalten</h4>
                            <ul class="lib-functions-list">
                              {functionsForItem(item).map((fn) => (
                                <li>
                                  <label class="lib-function-toggle">
                                    <input type="checkbox" class="lib-feature-toggle" data-feature-name={fn} data-default="true" checked />
                                    <span>{fn}</span>
                                  </label>
                                </li>
                              ))}
                            </ul>
                          </>
                        )}
                        {checksForItem(item).length > 0 && (
                          <>
                            <h4>Checks / NOGO</h4>
                            <ul class="lib-functions-list lib-functions-list--warn">
                              {checksForItem(item).map((check) => <li>{check}</li>)}
                            </ul>
                          </>
                        )}
                      </section>
                    )}
                  </div>

                  <div class="lib-meta">
                    <h3>{item.name}</h3>
                    <p class="small lib-component-id">ID: <code>{`${category.id}--${toSlug(item.name)}`}</code></p>
                    <div class="lib-validation" data-validation hidden></div>

                    <details class="lib-meta-details">
                      <summary>Details</summary>
                      <p class="small">{item.description}</p>
                      <dl class="lib-specs">
                        <dt>Typ</dt><dd><input class="lib-edit-input" data-field="type" data-default={item.type} value={item.type} /></dd>
                        <dt>Höhe</dt><dd><input class="lib-edit-input" data-field="height" data-default={item.height} value={item.height} /></dd>
                        <dt>Breite / Verhalten</dt><dd><input class="lib-edit-input" data-field="width" data-default={item.width} value={item.width} /></dd>
                        <dt>Padding</dt><dd><input class="lib-edit-input" data-field="padding" data-default={item.padding} value={item.padding} /></dd>
                        <dt>Border-Radius</dt><dd><input class="lib-edit-input" data-field="radius" data-default={item.radius} value={item.radius} /></dd>
                        <dt>Font-Size</dt><dd><input class="lib-edit-input" data-field="font" data-default={item.font} value={item.font} /></dd>
                        <dt>Icon-Größe</dt><dd><input class="lib-edit-input" data-field="icon" data-default={item.icon} value={item.icon} /></dd>
                        <dt>Touch-Target</dt><dd><input class="lib-edit-input" data-field="touch" data-default={item.touch} value={item.touch} /></dd>
                        <dt>Zustände</dt><dd><input class="lib-edit-input" data-field="states" data-default={item.states} value={item.states} /></dd>
                        <dt>Farben</dt><dd><input class="lib-edit-input" data-field="colors" data-default={item.colors || ""} value={item.colors || ""} placeholder="text:#E8EAF0, bg:#0B1220, border:#2A3550" /></dd>
                        <dt>Verwendungszweck</dt><dd><input class="lib-edit-input" data-field="usage" data-default={item.usage} value={item.usage} /></dd>
                        <dt>Funktionen</dt><dd><input class="lib-edit-input" data-field="features" data-default={item.features || ""} value={item.features || ""} /></dd>
                        <dt>Checks / NOGO</dt><dd><input class="lib-edit-input" data-field="checks" data-default={item.checks || ""} value={item.checks || ""} /></dd>
                      </dl>

                      <div class="lib-pattern-row">
                        <label class="small" for={`pattern-${category.id}-${toSlug(item.name)}`}>Pattern / Klassen</label>
                        <div class="lib-copy-wrap">
                          <input
                            id={`pattern-${category.id}-${toSlug(item.name)}`}
                            class="lib-pattern-input lib-edit-input"
                            data-field="patterns"
                            data-default={item.patterns}
                            value={item.patterns}
                          />
                          <button type="button" class="feed-btn feed-btn--ghost lib-copy-btn">FIX</button>
                        </div>
                      </div>
                      <div class="lib-pattern-row">
                        <label class="small" for={`notes-${category.id}-${toSlug(item.name)}`}>Bemerkungen / Anregungen</label>
                        <textarea
                          id={`notes-${category.id}-${toSlug(item.name)}`}
                          class="lib-edit-input lib-note-input"
                          data-field="notes"
                          data-default={item.notes || ""}
                          rows={3}
                          placeholder="Konkreter Hinweis, Problem, gewünschtes Ziel..."
                        >{item.notes || ""}</textarea>
                      </div>
                    </details>
                  </div>
                </article>
              ))
            }
            </div>
          </div>
        </div>
      </section>
    ))
  }
  <script src="/js/component-library.js" defer></script>


  <style>
    .lib-hero{
      display:grid;
      gap:10px;
    }

    .lib-principles{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
    }

    .lib-editor-controls{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top:4px;
    }

    .lib-export-row{
      display:grid;
      gap:6px;
      margin:0;
    }

    .lib-export-row textarea{
      width:100%;
      min-height:110px;
      font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size:.82rem;
      line-height:1.4;
      border:1px solid var(--line);
      border-radius:10px;
      padding:8px 10px;
      background:rgba(255,255,255,.03);
      color:var(--text);
    }

    .lib-principle{
      border:1px solid var(--line);
      border-radius:999px;
      padding:6px 10px;
      background:rgba(255,255,255,.04);
      font-size:.85rem;
      color:var(--text);
    }

    .lib-token-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));
      gap:10px;
    }

    .lib-token-card{
      border:1px solid var(--line);
      border-radius:12px;
      padding:10px;
      background:rgba(255,255,255,.03);
    }

    .lib-token-card h3{
      margin:0 0 6px;
      font-size:1rem;
      text-align:left;
    }

    .lib-token-card p{
      margin:0;
    }

    .lib-section-head{
      margin-bottom:12px;
    }

    .lib-section-head h2{
      margin-bottom:6px;
      text-align:left;
    }

    .lib-component-grid{
      display:grid;
      gap:12px;
    }

    .lib-component-card{
      border:1px solid var(--line);
      border-radius:14px;
      background:rgba(255,255,255,.03);
      overflow:visible;
      display:grid;
      grid-template-columns:minmax(260px, .95fr) minmax(280px, 1.05fr);
    }

    .lib-component-card.is-disabled{
      opacity:.58;
      filter:saturate(.68);
    }

    .lib-preview{
      border-right:1px solid var(--line);
      padding:10px;
      display:grid;
      gap:8px;
      align-content:start;
      background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
    }

    .lib-functions{
      display:grid;
      gap:6px;
      border:1px solid var(--line);
      border-radius:10px;
      padding:10px;
      background:rgba(255,255,255,.02);
    }

    .lib-functions h4{
      margin:0;
      font-size:.82rem;
      letter-spacing:.02em;
      text-transform:uppercase;
      color:var(--muted);
    }

    .lib-functions-list{
      margin:0;
      padding-left:18px;
      display:grid;
      gap:4px;
      font-size:.84rem;
      line-height:1.35;
    }

    .lib-functions-list--warn li{
      color:#ffd9a8;
    }

    .lib-function-toggle{
      display:grid;
      grid-template-columns:auto minmax(0, 1fr);
      align-items:flex-start;
      gap:6px;
    }

    .lib-function-toggle input{
      margin-top:2px;
      accent-color:#6fe2b4;
    }

    .lib-status-wrap{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:8px;
    }

    .lib-enable-toggle{
      display:inline-flex;
      align-items:center;
      gap:6px;
      font-size:.76rem;
      color:var(--muted);
      white-space:nowrap;
    }

    .lib-enable-toggle input{
      margin:0;
      accent-color:#6fe2b4;
    }

    .lib-status{
      display:inline-flex;
      align-items:center;
      border-radius:999px;
      padding:4px 9px;
      font-size:.72rem;
      font-weight:700;
      border:1px solid var(--line);
      text-transform:uppercase;
      letter-spacing:.04em;
    }

    .lib-status.is-standard{
      background:rgba(58,212,91,.2);
      border-color:rgba(58,212,91,.5);
    }

    .lib-status.is-review{
      background:rgba(255,200,48,.2);
      border-color:rgba(255,200,48,.5);
    }

    .lib-status.is-legacy{
      background:rgba(255,118,118,.2);
      border-color:rgba(255,118,118,.5);
    }

    .lib-preview-block{
      min-height:110px;
      border:1px dashed rgba(220,228,241,.24);
      border-radius:12px;
      padding:10px;
      display:grid;
      gap:8px;
      align-content:center;
      justify-items:start;
    }

    .lib-preview-buttons{
      justify-items:flex-start;
    }

    .lib-danger-btn{
      min-height:var(--touch-target-min);
      border-radius:12px;
      border:1px solid rgba(255,118,118,.6);
      background:rgba(178,43,43,.42);
      color:#fff;
      padding:0 16px;
      font-weight:700;
    }

    .lib-preview-inputs{
      width:100%;
    }

    .lib-preview-inputs input,
    .lib-preview-inputs select,
    .lib-preview-inputs textarea{
      width:100%;
    }

    .lib-check-set{
      display:flex;
      flex-wrap:wrap;
      align-items:center;
      gap:10px;
    }

    .lib-preview-chips{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      align-content:flex-start;
    }

    .lib-preview-cards .card{
      width:100%;
      box-shadow:none;
    }

    .lib-preview-nav{
      width:100%;
    }

    .lib-mock-header{
      width:100%;
