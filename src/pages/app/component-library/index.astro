import Site from "../../../layouts/Site.astro";
import { APP } from "../../../config/app";

const toSlug = (value) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");

const statusClass = (status) => {
  if (status === "Standard") return "is-standard";
  if (status === "In Prüfung") return "is-review";
  return "is-legacy";
};

const inputPreview = (variant): { type: "text" | "search"; value: string } => {
  if (variant === "search") {
    return { type: "search", value: "Mitglied suchen..." };
  }
  return { type: "text", value: "Demo Text" };
};

const splitCsv = (value) =>
  String(value || "")
    .split(",")
    .map((entry) => entry.trim())
    .filter(Boolean);

const functionsForItem = (item) => {
  if (item.features) return splitCsv(item.features);
  if (item.variant === "table") return ["Rows scanbar", "Header sortierbar", "Filterbar anbindbar"];
  if (item.variant === "row") return ["Row klickbar", "Dialog öffnet bei Row-Klick"];
  if (item.variant === "view-toggle") return ["Umschalten Tabelle/Karte", "Aktiver Zustand sichtbar"];
  return [];
};

const checksForItem = (item) => {
  if (item.checks) return splitCsv(item.checks);
  return [];
};

