---
import path from "node:path";
import Site from "../../../layouts/Site.astro";
import { APP } from "../../../config/app";
import { readMaskJsonFile } from "../../../../scripts/fcp-mask-reader.mjs";

const maskFilePath = path.resolve(process.cwd(), "docs/masks/templates/QFM_einstellungen.json");
const resolvedMask = await readMaskJsonFile(maskFilePath);

function toQuickFlowField(field) {
  const typeMap = {
    input: field.type === "email" ? "email" : field.type === "date" ? "date" : "text",
    textarea: "textarea",
    select: "select",
    toggle: "toggle",
    date: "date",
    email: "email",
    phone: "text",
    number: "number",
    readonly: "text",
    custom: "text",
  };

  return {
    name: field.name,
    label: field.label,
    type: typeMap[field.componentType] || field.type || "text",
    value: field.defaultValue ?? "",
    placeholder: field.placeholder || "",
    help: field.helpText || "",
    disabled: field.readonly === true,
    valuePath: field.valuePath || "",
    payloadKey: field.payloadKey || field.name,
    readonly: field.readonly === true,
    defaultValue: field.defaultValue ?? "",
    autocomplete:
      field.componentType === "email"
        ? "email"
        : field.componentType === "phone"
          ? "tel"
          : undefined,
    options: Array.isArray(field.options) ? field.options : [],
    span: field.displaySpan || undefined,
  };
}

function mapAction(action) {
  return {
    id: action.id,
    label: action.label,
    variant: action.kind === "rpc" || action.kind === "auth_action" ? "primary" : "ghost",
    binding: action.binding || null,
  };
}

function toQuickFlowPanel(panel, index) {
  const content = panel.content || {};
  const transformed = {
    id: panel.id,
    title: panel.title,
    renderMode: panel.renderMode,
    componentType: panel.componentType || null,
    flowType: panel.flowType,
    permissions: panel.permissions,
    open: index === 0,
    meta: {
      label: panel.meta?.displayLabel || "",
      securityContext: panel.securityContext,
      processAdapter: panel.meta?.processAdapter || "",
      resolver: {
        fieldDefs: content.fields || [],
        blockDefs: content.blocks || [],
      },
    },
    loadBinding: panel.loadBinding,
    saveBinding: panel.saveBinding,
    content: {
      fields: [],
      rows: [],
      actions: [],
      blocks: [],
    },
    actions: [],
    rows: [],
    columns: [],
    tableConfig: panel.tableConfig || null,
  };

  if (panel.renderMode === "form") {
    transformed.content.fields = (content.fields || []).map(toQuickFlowField);
  } else if (panel.renderMode === "readonly") {
    transformed.content.rows = [];
  } else if (panel.renderMode === "actions") {
    transformed.actions = (content.actions || []).map(mapAction);
  } else if (panel.renderMode === "mixed") {
    transformed.content.blocks = [];
  } else if (panel.renderMode === "table") {
    transformed.columns = panel.columns || [];
    transformed.rows = panel.rows || [];
  }

  return transformed;
}

function toQuickFlowSection(section) {
  return {
    id: section.id,
    label: section.label,
    title: section.title,
    description: section.description,
    permissions: section.permissions,
    panels: (section.panels || []).map((panel, index) => toQuickFlowPanel(panel, index)),
  };
}

const qfmPilotConfig = {
  root: "#settingsQfmRoot",
  maskId: resolvedMask.maskId,
  maskFamily: resolvedMask.maskFamily || "QFM",
  maskType: resolvedMask.maskType,
  activeSectionId: resolvedMask.sections[0]?.id || null,
  autoLoadOnInit: false,
  autoLoadSectionOnActivate: false,
  autoLoadPanelOnOpen: false,
  currentRoles: ["member"],
  currentScopes: {
    globalUser: true,
    authSystem: true,
    clubReadonly: true,
    clubOverride: false,
    billingSnapshot: true,
    consentAppendOnly: true,
  },
  header: resolvedMask.header,
  sections: resolvedMask.sections.map(toQuickFlowSection),
};

const qfmPilotConfigJson = JSON.stringify(qfmPilotConfig);

---

<Site title={`Einstellungen • ${APP.name}`} description="QFM-basierter Pilot fuer die neue Settings-Maske." robots="noindex">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/ofmMask.css" />
  </Fragment>

  <section class="ofm-mask-stage">
    <div id="settingsQfmRoot"></div>
    <p id="settingsQfmPilotMsg" class="small ofm-mask-stage__status" aria-live="polite"></p>
  </section>

  <script is:inline src="/js/fcp-mask-process-state.js"></script>
  <script is:inline src="/js/fcp-adm-qfm-contract-hub.js"></script>
  <script is:inline src="/js/fcp-mask-data-resolver.js"></script>
  <script is:inline src="/js/fcp-data-table.js"></script>
  <script is:inline src="/js/fcp-inline-data-table-v2.js"></script>
  <script is:inline src="/js/quick-flow-pattern.js"></script>
  <script is:inline src="/js/fcp-mask-page-loader.js"></script>
  <script id="settingsQfmConfig" type="application/json" set:html={qfmPilotConfigJson}></script>
  <script is:inline>
    const pilotMsgEl = document.getElementById("settingsQfmPilotMsg");

    function setPilotMessage(text) {
      if (pilotMsgEl) pilotMsgEl.textContent = text;
    }

    window.FcpMaskPageLoader.boot({
      configScriptId: "settingsQfmConfig",
      patternGlobal: "__QFM_SETTINGS_PILOT__",
      onMessage: setPilotMessage,
    }).catch((error) => {
      setPilotMessage(error instanceof Error ? error.message : String(error));
    });
  </script>

  <style>
    .ofm-mask-stage {
      display: grid;
      gap: 10px;
    }
    #settingsQfmRoot {
      min-height: 240px;
    }
    .ofm-mask-stage__status {
      margin: 0;
    }
  </style>
</Site>
