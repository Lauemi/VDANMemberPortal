---
import Site from "../../../layouts/Site.astro";
import { APP } from "../../../config/app";
---

<Site title={`Fangliste • ${APP.name}`} description="Digitale Fangliste" robots="noindex">
  <section class="card" data-studio-component-id="fangliste-header-card" data-studio-component-type="card" data-studio-slot="main">
    <div class="card__body" data-studio-component-id="fangliste-header-content" data-studio-component-type="section" data-studio-slot="main">
      <div class="catch-table-toolbar">
        <h1>Fangliste / Angeltage</h1>
        <div class="fangliste-add-anchor">
          <button
            type="button"
            id="tripCreateOpenTop"
            class="catch-add-btn catch-add-btn--top"
            aria-label="Fang hinzufügen"
            aria-expanded="false"
            aria-controls="tripTopMenu"
            data-studio-component-id="fangliste-open-create-top-btn"
            data-studio-component-type="button"
            data-studio-slot="main"
          >+</button>
          <div id="tripTopMenu" class="fangliste-action-menu fangliste-action-menu--top hidden" hidden>
            <button type="button" id="tripTopCatch" class="fangliste-fab-action">
              <span class="fangliste-fab-action__label">Fang erfassen</span>
            </button>
            <button type="button" id="tripTopNoCatch" class="fangliste-fab-action fangliste-fab-action--ghost">
              <span class="fangliste-fab-action__label">Kein Fang</span>
            </button>
          </div>
        </div>
      </div>
      <p class="small">Klicke auf eine Zeile für Details. Bilder können im Dialog hinterlegt werden.</p>

      <p id="tripMsg" class="small" aria-live="polite"></p>
    </div>
  </section>

  <section class="card" data-studio-component-id="fangliste-main-card" data-studio-component-type="card" data-studio-slot="main">
    <div class="card__body" data-studio-component-id="fangliste-main-content" data-studio-component-type="section" data-studio-slot="main">
      <h2>Meine Angeltage</h2>

      <div class="trip-table-toolbar" role="region" aria-label="Tabellensteuerung" data-studio-component-id="fangliste-table-toolbar" data-studio-component-type="section" data-studio-slot="main">
        <label class="trip-table-search">
          <span class="visually-hidden">Suche in der Fangliste</span>
          <input id="tripSearch" type="search" placeholder="Suche Tag, Gewässer, Fang, Gewicht, Anzahl..." data-studio-component-id="fangliste-search-input" data-studio-component-type="input" data-studio-slot="main" />
        </label>
        <div class="trip-table-toolbar__actions">
          <span id="tripActiveFilterCount" class="trip-filter-meta hidden" aria-live="polite">0 Filter aktiv</span>
          <label class="trip-inline-check">
            <input id="tripOnlyNoCatch" type="checkbox" /> Nur Kein Fang
          </label>
          <div class="ui-view-toggle" role="group" aria-label="Ansicht">
            <button type="button" class="feed-btn" id="tripViewZeileBtn" data-ansicht="zeile">Tabelle</button>
            <button type="button" class="feed-btn feed-btn--ghost" id="tripViewKarteBtn" data-ansicht="karte">Cards</button>
          </div>
          <button type="button" class="feed-btn feed-btn--ghost" id="tripResetFiltersBtn">Reset Filter</button>
        </div>
      </div>

      <div
        id="tripList"
        class="fangliste-list"
        style="margin-top:10px"
        data-studio-component-id="fangliste-list-table"
        data-studio-component-type="table"
        data-studio-slot="main"
        data-studio-library-id="lists--standard-tabelle"
        data-table-id="fangliste"
        data-row-click="dialog"
      ></div>
    </div>
  </section>

  <section class="card" data-studio-component-id="fangliste-stats-card" data-studio-component-type="card" data-studio-slot="main">
    <div class="card__body" data-studio-component-id="fangliste-stats-content" data-studio-component-type="section" data-studio-slot="main">
      <h2>Meine Stats</h2>
      <p class="small">Deine Angeltage, Kein-Fang-Tage, Gesamtfänge und letzter Eintrag.</p>
      <p id="tripStatsMsg" class="small" aria-live="polite"></p>
      <div id="tripStatsBox" class="fangliste-list"></div>
    </div>
  </section>

  <section id="tripCreateDialog" class="catch-dialog catch-dialog--panel hidden" data-guard-sheet="1" hidden data-studio-component-id="fangliste-create-dialog" data-studio-component-type="dialog" data-studio-slot="main">
    <form id="tripCreateForm" class="catch-dialog__form">
      <h3 id="tripCreateTitle">Eintrag erfassen</h3>

      <div class="fangliste-form-grid">
        <label>
          <span>Datum</span>
          <input id="tripDate" type="date" required />
        </label>

        <label>
          <span>Gewässer suchen</span>
          <input id="tripWaterSearch" type="search" placeholder="Gewässer filtern..." />
        </label>

        <label class="fangliste-full">
          <span>Gewässer</span>
          <select id="tripWater" required></select>
        </label>

        <div class="fangliste-full fangliste-water-favorites">
          <div class="fangliste-water-favorites__actions">
            <button type="button" id="tripWaterFavoriteToggle" class="feed-btn feed-btn--ghost" disabled>Als Favorit merken</button>
          </div>
          <div id="tripWaterFavorites" class="fangliste-water-chip-list" role="group" aria-label="Favoriten Gewässer"></div>
        </div>

        <label class="fangliste-catch-only">
          <span>Fischart (optional)</span>
          <select id="tripFishSpecies"></select>
        </label>

        <label class="fangliste-catch-only">
          <span>Anzahl (optional, Standard 1)</span>
          <input id="tripQty" type="number" min="1" step="1" value="1" />
        </label>

        <label class="fangliste-catch-only">
          <span>Länge in cm (optional)</span>
          <input id="tripLength" type="number" min="0" step="0.1" />
        </label>

        <label class="fangliste-catch-only">
          <span>Gewicht in g (optional)</span>
          <input id="tripWeight" type="number" min="0" step="1" />
        </label>

        <label class="fangliste-full">
          <span>Bild (optional)</span>
          <input id="tripCreatePhoto" type="file" accept="image/*" />
        </label>
      </div>

      <div class="catch-dialog__actions">
        <button type="submit" id="tripCreateSubmit" class="feed-btn">Speichern</button>
        <button type="button" id="tripCreateClose" class="feed-btn feed-btn--ghost">Schließen</button>
      </div>
      <p id="tripCreateMsg" class="small" aria-live="polite"></p>
    </form>
  </section>

  <section id="tripDetailDialog" class="catch-dialog catch-dialog--panel hidden" data-guard-sheet="1" hidden data-studio-component-id="fangliste-detail-dialog" data-studio-component-type="dialog" data-studio-slot="main">
    <form id="tripDetailForm" class="catch-dialog__form">
      <h3>Eintragsdetails</h3>
      <div id="tripDetailBody" class="catch-dialog__body"></div>
      <div class="catch-dialog__actions">
        <button type="button" id="tripDeleteEntryBtn" class="feed-btn feed-btn--ghost">Eintrag löschen</button>
        <button type="button" id="tripDetailSaveChanges" class="feed-btn">Änderungen speichern</button>
        <button type="button" id="tripDetailClose" class="feed-btn feed-btn--ghost">Schließen</button>
      </div>
      <p id="tripDetailMsg" class="small" aria-live="polite"></p>
    </form>
  </section>

  <div class="catch-fab-stack fangliste-fab-stack">
    <div id="tripFabMenu" class="fangliste-action-menu fangliste-action-menu--fab hidden" hidden>
      <button type="button" id="tripFabCatch" class="fangliste-fab-action">
        <span class="fangliste-fab-action__label">Fang erfassen</span>
      </button>
      <button type="button" id="tripFabNoCatch" class="fangliste-fab-action fangliste-fab-action--ghost">
        <span class="fangliste-fab-action__label">Kein Fang</span>
      </button>
    </div>
    <button
      type="button"
      id="tripCreateFab"
      class="catch-add-btn catch-add-btn--fab"
      aria-label="Fang hinzufügen"
      aria-expanded="false"
      aria-controls="tripFabMenu"
      data-studio-component-id="fangliste-open-create-fab"
      data-studio-component-type="button"
      data-studio-slot="main"
    >+</button>
  </div>

  <script src="/js/catchlist.js" defer></script>

  <style>
    .fangliste-add-anchor {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }

    .fangliste-fab-stack {
      flex-direction: column;
      align-items: flex-end;
      gap: 10px;
    }

    .fangliste-action-menu {
      display: grid;
      gap: 8px;
      justify-items: stretch;
    }

    .fangliste-action-menu--top {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      min-width: 220px;
      z-index: 4;
    }

    .fangliste-action-menu--fab {
      justify-items: end;
    }

    .fangliste-fab-action {
      min-height: 42px;
      padding: 0 14px;
      border-radius: 999px;
      border: 1px solid rgba(78, 161, 255, .44);
      background: linear-gradient(180deg, rgba(64, 103, 182, .92), rgba(31, 57, 109, .96));
      color: var(--text);
      font: inherit;
      font-weight: 700;
      box-shadow: 0 10px 24px rgba(0, 0, 0, .26);
    }

    .fangliste-fab-action--ghost {
      background: rgba(17, 27, 45, .96);
    }

    .fangliste-fab-action__label {
      white-space: nowrap;
    }

    #tripCreateFab[aria-expanded="true"],
    #tripCreateOpenTop[aria-expanded="true"] {
      background: rgba(78, 161, 255, .36);
      border-color: rgba(120, 184, 255, .7);
    }

    @media (min-width: 900px) {
      .fangliste-fab-stack {
        display: none;
      }
    }

    @media (max-width: 899px) {
      .fangliste-add-anchor {
        display: none;
      }
    }
  </style>
</Site>
