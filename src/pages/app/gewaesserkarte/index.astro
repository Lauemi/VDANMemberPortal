---
import Site from "../../../layouts/Site.astro";
import { APP } from "../../../config/app";
const isVdanMode = APP.siteMode === "vdan";
---

<Site title={`Gewässerkarte • ${APP.name}`} description="Karte mit Mitglieds-Berechtigungen." robots="noindex">
  <section class="card">
    <div class="card__body">
      <h1>Gewässerkarte</h1>
      {isVdanMode ? (
        <>
          <p class="small">Grün = Erlaubt, Rot = Verboten (laut Karte/Profil).</p>
          <p id="waterMapMsg" class="small" aria-live="polite"></p>
          <div style="margin:8px 0 10px;">
            <button id="waterLocateBtn" class="feed-btn" type="button">Mein Standort</button>
          </div>

          <div id="waterMapCanvas" style="height:480px;border:1px solid var(--line);border-radius:12px;overflow:hidden;"></div>
          <div id="waterMapList" class="grid" style="margin-top:12px;"></div>
        </>
      ) : (
        <>
          <p class="small">Dieses Modul ist nur im VDAN-Modus verfügbar.</p>
          <p class="small"><a href="/app/">Zurück zum Portal</a></p>
        </>
      )}
    </div>
  </section>

  {isVdanMode && <script src="/js/member-water-map.js" defer></script>}
</Site>
