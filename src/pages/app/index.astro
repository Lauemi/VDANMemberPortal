---
import Site from "../../layouts/Site.astro";
import { APP } from "../../config/app";
import pkg from "../../../package.json";

function envText(value: unknown, fallback: string) {
  const text = String(value ?? "").trim();
  return text || fallback;
}

const appVersionEnv = String(import.meta.env.PUBLIC_APP_VERSION ?? "").trim();
const deploySha = envText(
  import.meta.env.PUBLIC_DEPLOY_SHA,
  envText(import.meta.env.VERCEL_GIT_COMMIT_SHA, envText(import.meta.env.GITHUB_SHA, "")),
);
const deployRef = envText(
  import.meta.env.PUBLIC_DEPLOY_REF,
  envText(import.meta.env.VERCEL_GIT_COMMIT_REF, envText(import.meta.env.GITHUB_REF_NAME, "")),
);
const buildStamp = envText(import.meta.env.PUBLIC_BUILD_STAMP, "");
const autoAppVersion = [
  `v${String(pkg?.version || "0.1.0").trim()}`,
  deployRef ? deployRef.replace(/[^a-zA-Z0-9._-]+/g, "-") : "",
  deploySha ? deploySha.slice(0, 7) : buildStamp || "dev-local",
].filter(Boolean).join("+");
const assetVersion = encodeURIComponent(appVersionEnv && appVersionEnv !== "dev-local" ? appVersionEnv : autoAppVersion);
---

<Site title={`Fishing-Club-Portal • ${APP.name}`} description="Memberbereich." robots="noindex">
  <section class="app-portal-shell" data-studio-component-id="app-home-shell" data-studio-component-type="section" data-studio-slot="main">
    <div class="app-portal" data-studio-component-id="app-home-content" data-studio-component-type="section" data-studio-slot="main">
      <div class="app-portal-guest hidden" data-guest-only hidden data-studio-component-id="app-home-guest-hero" data-studio-component-type="card" data-studio-slot="main">
        <picture class="app-portal-guest__logo" aria-hidden="true">
          <source srcset={`/Branding/New_FCP_GoFishing.svg?v=${assetVersion}`} type="image/svg+xml" />
          <img src={`/Branding/New_FCP_GoFishing.svg?v=${assetVersion}`} alt="" loading="eager" decoding="async" />
        </picture>
        <p class="app-portal-guest__message">{APP.guestLoginMessage}</p>
        <a class="feed-btn" href="/login/?next=%2Fapp%2F">{APP.guestLoginCtaLabel}</a>
      </div>

      <section class="app-dashboard hidden" data-member-only hidden data-studio-component-id="app-home-dashboard" data-studio-component-type="section" data-studio-slot="main">


       

        <div class="app-dashboard__hero" data-studio-component-id="app-home-member-layout-head" data-studio-component-type="section" data-studio-slot="main">
          <div class="app-dashboard__copy">
            <p class="app-dashboard__layout-title">Dashboard Layout</p>
      
          </div>
          <a class="app-dashboard__settings" href="/app/einstellungen/" aria-label="Einstellungen öffnen" title="Einstellungen öffnen">⚙</a>
        </div>

        <div class="fcp-dashboard-grid" data-studio-component-id="app-home-app-grid" data-studio-component-type="section" data-studio-slot="main">
          <section
            id="portalDecisionWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--hero"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="decision"
          ></section>
          <section
            id="portalPressureWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--narrow"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="stat"
          ></section>
          <section
            id="portalWindWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--narrow"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="stat"
          ></section>
          <section
            id="portalTempWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--narrow"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="stat"
          ></section>
          <section
            id="portalTasksWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--wide fcp-dashboard-slot--action"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="list"
          ></section>
          <section
            id="portalEventsWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--wide fcp-dashboard-slot--action"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="list"
          ></section>
          <section
            id="portalCatchRatioWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--narrow fcp-dashboard-slot--identity"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="stat"
          ></section>
          <section
            id="portalTripDaysWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--narrow fcp-dashboard-slot--identity"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="stat"
          ></section>
          <section
            id="portalCalendarWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--compact fcp-dashboard-slot--tool"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="calendar"
          ></section>
          <section
            id="portalCompassWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--compact fcp-dashboard-slot--tool"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="stat"
          ></section>
          <section
            id="portalLastCatchWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--compact fcp-dashboard-slot--tool"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="stat"
          ></section>
          <section
            id="portalSunWidget"
            class="fcp-dashboard-slot fcp-dashboard-slot--compact fcp-dashboard-slot--tool"
            data-fcp-component="FCP Dashboard Widget v1"
            data-dashboard-widget-kind="chart"
          ></section>
        </div>
      </section>
    </div>
  </section>
  <script src="/js/fcp-dashboard.js" defer></script>
  <script src="/js/app-dashboard.js" defer></script>
</Site>
