---
import fs from "node:fs";
import path from "node:path";
import Site from "../../../layouts/Site.astro";
import { APP } from "../../../config/app";

const repoRoot = process.cwd();
const masterBootstrapPath = path.join(repoRoot, "docs", "FCP_company", "fcp_masterboard_state.json");
const processBootstrapPath = path.join(repoRoot, "docs", "FCP_company", "fcp_process_control_state.json");

const masterBootstrap = JSON.parse(fs.readFileSync(masterBootstrapPath, "utf8"));
const processBootstrap = JSON.parse(fs.readFileSync(processBootstrapPath, "utf8"));
const bootstrapScript = [
  `window.__FCP_MASTERBOARD_BOOTSTRAP__ = ${JSON.stringify(masterBootstrap).replace(/</g, "\\u003c")};`,
  `window.__FCP_PROCESS_CONTROL_BOOTSTRAP__ = ${JSON.stringify(processBootstrap).replace(/</g, "\\u003c")};`,
].join("\n");
---

<Site
  title={`Masterboard • ${APP.name}`}
  description="Superadmin-Systemboard für Architektur, Launch-Risiken und operativen Kontrollstand."
  robots="noindex"
  containerClass="container container--admin-wide"
>
  <link slot="head" rel="stylesheet" href="/css/masterboard.css" />

  <section class="card masterboard-page">
    <div class="card__body">
      <h1>FCP Masterboard</h1>
      <p class="small">
        Systemboard für Architektur, operative Kontrolle und Launch-Risiko.
        Diese Maske ist ausschließlich für Superadmin gedacht und schreibt ihren Zustand direkt in die Datenbank.
      </p>
      <p id="masterboardPageMsg" class="small" aria-live="polite"></p>
    </div>
  </section>

  <section class="card masterboard-page masterboard-page--workspace">
    <div class="card__body">
      <div id="fcpMasterboardApp" class="masterboard-app">
        <div class="masterboard-app__startshell">
          <section class="titlebox titlebox--primary">
            <div class="eyebrow">Systemsteuerung</div>
            <h2>FCP Systemboard</h2>
            <p class="subtitle">Zentrale Sicht auf Architektur, Prozessreife, Risiken und offene Systemlücken.</p>
            <div class="golden">Golden Path: Website → Registrierung → Login → Onboarding → CSV → Dashboard → Nutzung</div>
            <p class="masterboard-intent">
              Ziel dieser Maske ist gefuehrte Arbeit: Blocker, Relationen, betroffene Screens und konkrete Arbeitsanker sollen direkt in den passenden Arbeitskontext fuehren.
            </p>
          </section>

          <section class="guidebox guidebox--blockers guidebox--start">
            <div class="eyebrow">Top 3 Blocker</div>
            <p class="guidebox__lead guidebox__lead--primary">
              Arbeitsstart: zuerst Blocker oeffnen, dann von dort in Knoten, Prozess, Screen oder Arbeitsanker verzweigen.
            </p>
            <p id="masterboardTopBlockersSummary" class="small masterboard-top-summary"></p>
            <div id="masterboardTopBlockers" class="blocker-list"></div>
          </section>
        </div>

        <div class="masterboard-app__controlrail">
          <section class="guidebox guidebox--context">
            <div class="eyebrow">Führung</div>
            <div class="mode-switch" role="tablist" aria-label="Board-Modus">
              <button type="button" class="tab active" data-masterboard-mode="lead">Führung</button>
              <button type="button" class="tab" data-masterboard-mode="detail">Detail</button>
            </div>
            <p id="masterboardModeHint" class="mode-hint">
              Fokusmodus: priorisierte Arbeitsstarts, Blocker und kritische Pfade zuerst.
            </p>
            <p class="guidebox__lead">
              Modus, Legende und Signale rahmen die Arbeit. Der primaere Einstieg in offene Fuehrungsarbeit liegt rechts bei den Top-3-Blockern.
            </p>
            <div class="legend-list">
              <div><span class="legend-dot is-red"></span> Rot = Blocker</div>
              <div><span class="legend-dot is-yellow"></span> Gelb = offen / Entscheidung fehlt</div>
              <div><span class="legend-dot is-green"></span> Grün = stabil</div>
              <div><span class="legend-mark">L1/L2/L3</span> Launch-Klasse / Reife</div>
              <div><span class="legend-mark">!</span> Risiko hoch</div>
              <div><span class="legend-mark">~</span> Gap / Luecke offen</div>
              <div><span class="legend-mark">✦</span> Golden-Path-relevant</div>
            </div>
          </section>

          <section class="filterbox filterbox--secondary">
            <div class="eyebrow">Filter</div>
            <div class="filter-grid">
              <label class="control">
                <span>Suche</span>
                <input id="masterboardSearch" type="search" placeholder="Modul, Gap, Ref ..." />
              </label>
              <label class="control">
                <span>Ebene</span>
                <select id="masterboardLaneFilter">
                  <option value="all">Alle Ebenen</option>
                </select>
              </label>
              <label class="control">
                <span>Status</span>
                <select id="masterboardStatusFilter">
                  <option value="all">Alle Status</option>
                  <option value="erfuellt">Erfüllt</option>
                  <option value="teilweise">Teilweise</option>
                  <option value="offen">Offen</option>
                </select>
              </label>
              <label class="control">
                <span>Signal</span>
                <select id="masterboardSignalFilter">
                  <option value="all">Alle Signale</option>
                  <option value="risk">Nur Risiken</option>
                  <option value="gap">Nur Lücken</option>
                  <option value="focus">Nur Golden Path</option>
                </select>
              </label>
            </div>
          </section>

          <section class="actionbox actionbox--secondary">
            <div class="eyebrow">Zustand</div>
            <div class="masterboard-source">
              <span class="masterboard-source__label">Datenquelle</span>
              <span id="masterboardSourceBadge" class="masterboard-source__badge is-loading">Lade…</span>
            </div>
            <div class="stats">
              <div class="stat"><div class="k">Knoten</div><div class="v" id="masterboardStatNodes">0</div></div>
              <div class="stat"><div class="k">Lücken</div><div class="v" id="masterboardStatGaps">0</div></div>
              <div class="stat"><div class="k">Risiken</div><div class="v" id="masterboardStatRisks">0</div></div>
              <div class="stat"><div class="k">Prozesse</div><div class="v" id="masterboardStatProcesses">0</div></div>
            </div>
            <div class="btnrow">
              <button type="button" class="primary" id="masterboardRefreshBtn">Neu laden</button>
              <button type="button" class="ghost" id="masterboardSeedBtn">Bootstrap übernehmen</button>
              <button type="button" class="ghost" id="masterboardExportMasterBtn">Master export</button>
              <button type="button" class="ghost" id="masterboardExportOpsBtn">Ops export</button>
            </div>
            <p class="masterboard-intent masterboard-intent--small">
              Die Statistik folgt den aktiven Filtern und zeigt den aktuell gefuehrten Arbeitsfokus.
            </p>
          </section>
        </div>

        <div class="tabs">
          <button type="button" class="tab active" data-masterboard-tab="master">Masterboard</button>
          <button type="button" class="tab" data-masterboard-tab="ops">Operatives Kontrollboard</button>
        </div>

        <div id="masterboardMasterView">
          <div id="masterboardLaneBoard" class="board"></div>
        </div>

        <div id="masterboardOpsView" class="hidden">
          <div class="process-table process-head">
            <div>Prozess</div>
            <div>Screens</div>
            <div>UI</div>
            <div>Smoke</div>
            <div>Bugs</div>
            <div>Prioritaet</div>
            <div>Workbench</div>
          </div>
          <div id="masterboardProcessList"></div>
        </div>
      </div>
    </div>
  </section>

  <div id="masterboardOverlay" class="masterboard-overlay"></div>
  <aside id="masterboardDrawer" class="masterboard-drawer" aria-hidden="true" inert>
    <div class="masterboard-drawer__head">
      <div>
        <div id="masterboardDrawerLane" class="eyebrow">Details</div>
        <h2 id="masterboardDrawerTitle">Eintrag</h2>
        <p id="masterboardDrawerSub" class="subtitle">-</p>
      </div>
      <button type="button" class="ghost" id="masterboardDrawerClose">Schließen</button>
    </div>
    <div id="masterboardDrawerBody" class="masterboard-drawer__body"></div>
  </aside>

  <script is:inline set:html={bootstrapScript}></script>
  <script src="/js/masterboard-app.js" defer></script>
</Site>
