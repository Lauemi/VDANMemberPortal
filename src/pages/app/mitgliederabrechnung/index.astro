---
import path from "node:path";
import Site from "../../../layouts/Site.astro";
import { APP } from "../../../config/app";
import { readMaskJsonFile } from "../../../../scripts/fcp-mask-reader.mjs";

const maskFilePath = path.resolve(process.cwd(), "docs/masks/templates/Onboarding/ADM_clubSettings.json");
const resolvedMask = await readMaskJsonFile(maskFilePath);

const admConfig = {
  ...resolvedMask,
  workspaceNav: {
    ...resolvedMask.workspaceNav,
    defaultSectionId: "club_settings_abrechnung",
  },
  root: "#mitgliederabrechnungAdmRoot",
  currentRoles: ["admin", "vorstand", "superadmin"],
  currentScopes: {
    globalUser: true,
    authSystem: true,
    clubReadonly: true,
    clubOverride: true,
    billingSnapshot: false,
    consentAppendOnly: false,
  },
};

const admConfigJson = JSON.stringify(admConfig);
---

<Site
  title={`Mitgliederabrechnung • ${APP.name}`}
  description="ADM: Mitgliederabrechnung — Pflichtstunden, Soll/Ist/Delta"
  robots="noindex"
  containerClass="container container--admin-wide"
  admBreadcrumbs={["Operativ", "Mitgliederabrechnung"]}
>

  <div class="adm-workspace-header">
    <div class="adm-workspace-header__text">
      <p class="adm-workspace-header__kicker">Vereins-Abrechnung</p>
      <h1 class="adm-workspace-header__title">Mitgliederabrechnung</h1>
      <p class="adm-workspace-header__desc">
        Pflichtstunden Soll / Ist / Delta pro Mitglied. Grundlage für Verein→Mitglied-Abrechnung.
      </p>
    </div>
  </div>

  <section class="card">
    <div class="card__body">
      <div id="mitgliederabrechnungAdmRoot" class="fcp-table-root"></div>
      <p id="mitgliederabrechnungAdmMsg" class="small ofm-mask-stage__status" aria-live="polite"></p>
    </div>
  </section>

  <script is:inline src="/js/fcp-mask-process-state.js"></script>
  <script is:inline src="/js/fcp-adm-qfm-contract-hub.js"></script>
  <script is:inline src="/js/fcp-mask-data-resolver.js"></script>
  <script is:inline src="/js/fcp-data-table.js"></script>
  <script is:inline src="/js/fcp-inline-data-table-v2.js"></script>
  <script is:inline src="/js/fcp-roles-accordion.js"></script>
  <script is:inline src="/js/fcp-adm-qfm-shared-renderers.js"></script>
  <script is:inline src="/js/fcp-table-dialog-host.js"></script>
  <script is:inline src="/js/fcp-member-invite-dialog.js"></script>
  <script is:inline src="/js/domain-adapter-vereinsverwaltung.js"></script>
  <script is:inline src="/js/vereinsverwaltung-adm.js"></script>
  <script is:inline src="/js/admin-panel-mask.js"></script>
  <script is:inline src="/js/fcp-mask-page-loader.js"></script>
  <link rel="stylesheet" href="/css/redesign.css" />
  <script is:inline src="/js/redesign.js"></script>
  <script id="mitgliederabrechnungAdmConfig" type="application/json" set:html={admConfigJson}></script>
  <script is:inline>
    const admMsgEl = document.getElementById("mitgliederabrechnungAdmMsg");
    function setAdmMessage(text) {
      if (admMsgEl) admMsgEl.textContent = text || "";
    }
    window.FcpMaskPageLoader.boot({
      configScriptId: "mitgliederabrechnungAdmConfig",
      patternGlobal: "__ADM_MITGLIEDERABRECHNUNG__",
      rendererFamily: "ADM",
      onMessage: setAdmMessage,
    }).catch((error) => {
      setAdmMessage(error instanceof Error ? error.message : String(error));
    });
  </script>

  <style>
    #mitgliederabrechnungAdmRoot {
      min-height: 420px;
    }
    .ofm-mask-stage__status {
      margin: 10px 0 0;
    }
  </style>
</Site>
