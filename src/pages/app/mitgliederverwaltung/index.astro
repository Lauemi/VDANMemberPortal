---
import path from "node:path";
import Site from "../../../layouts/Site.astro";
import { APP } from "../../../config/app";
import { readMaskJsonFile } from "../../../../scripts/fcp-mask-reader.mjs";

const maskFilePath = path.resolve(process.cwd(), "docs/masks/templates/Onboarding/ADM_clubSettings.json");
const resolvedMask = await readMaskJsonFile(maskFilePath);

const admConfig = {
  ...resolvedMask,
  root: "#clubSettingsAdmRoot",
  currentRoles: ["admin", "vorstand", "superadmin"],
  currentScopes: {
    globalUser: true,
    authSystem: true,
    clubReadonly: true,
    clubOverride: true,
    billingSnapshot: true,
    consentAppendOnly: false,
  },
};

const admConfigJson = JSON.stringify(admConfig);
---

<Site title={`Mitgliederverwaltung • ${APP.name}`} description="ADM: Mitgliederverwaltung" robots="noindex" containerClass="container container--admin-wide" admBreadcrumbs={["ClubSettings", "Mitgliederverwaltung"]}>

  {/*
    Phase B — Workspace-Header
    WAS WAR: Kein eigener Page-Level-Header. Der ADM-Renderer erzeugte
             direkt seinen ersten Section-Titel (h2, ~28px) als oberste
             Ueberschrift — ohne Kicker, ohne Beschreibung, ohne Scope.
    WARUM: Ein Workspace-Header ordnet die Seite: Kicker benennt den
           Kontext (Onboarding Workspace), Titel benennt den Bereich,
           Beschreibung erklaert was hier passiert.
           Quelle: resolvedMask.header aus ADM_clubSettings.json.
    ACHTUNG: Dieser Header ist statisch-gerendert (Astro SSR).
             Er veraendert keine JS-Logik und keinen Renderer-State.
  */}
  <div class="adm-workspace-header">
    <div class="adm-workspace-header__text">
      {resolvedMask?.header?.kicker && (
        <p class="adm-workspace-header__kicker">{resolvedMask.header.kicker}</p>
      )}
      <h1 class="adm-workspace-header__title">
        {resolvedMask?.header?.title ?? "Vereinsverwaltung"}
      </h1>
      {resolvedMask?.header?.description && (
        <p class="adm-workspace-header__desc">{resolvedMask.header.description}</p>
      )}
    </div>
  </div>

  <section class="card">
    <div class="card__body">
      <div id="clubSettingsAdmRoot" class="fcp-table-root"></div>
      <p id="clubSettingsAdmMsg" class="small ofm-mask-stage__status" aria-live="polite"></p>
    </div>
  </section>

  <script is:inline src="/js/fcp-mask-process-state.js"></script>
  <script is:inline src="/js/fcp-adm-qfm-contract-hub.js"></script>
  <script is:inline src="/js/fcp-mask-data-resolver.js"></script>
  <script is:inline src="/js/fcp-data-table.js"></script>
  <script is:inline src="/js/fcp-inline-data-table-v2.js"></script>
  <script is:inline src="/js/fcp-adm-qfm-shared-renderers.js"></script>
  <script is:inline src="/js/fcp-table-dialog-host.js"></script>
  <script is:inline src="/js/domain-adapter-vereinsverwaltung.js"></script>
  <script is:inline src="/js/vereinsverwaltung-adm.js"></script>
  <script is:inline src="/js/admin-panel-mask.js"></script>
  <script is:inline src="/js/fcp-mask-page-loader.js"></script>
  <link rel="stylesheet" href="/css/redesign.css" />
  <script is:inline src="/js/redesign.js"></script>
  <script id="clubSettingsAdmConfig" type="application/json" set:html={admConfigJson}></script>
  <script is:inline>
    const admMsgEl = document.getElementById("clubSettingsAdmMsg");

    function setAdmMessage(text) {
      if (admMsgEl) admMsgEl.textContent = text || "";
    }

    // -------------------------------------------------------------------------
    // Freigaben: Approve / Reject — injected into the read-only table dialog
    // -------------------------------------------------------------------------
    // The club_settings_approvals_membership panel uses rowInteractionMode:"dialog"
    // but saveBinding.kind:"none" (no standard save). When a row is clicked the
    // dialog opens in read-only mode. We listen for the row-click event and
    // inject Genehmigen / Ablehnen buttons into the dialog actions area after it opens.

    (function () {
      const APPROVALS_PANEL = "club_settings_approvals_membership";

      function sbAuth(path, body) {
        const url = String(window.__APP_SUPABASE_URL || "").trim().replace(/\/+$/, "");
        const key = String(window.__APP_SUPABASE_KEY || "").trim();
        const session = window.VDAN_AUTH?.loadSession?.() || null;
        const token = session?.access_token || "";
        return fetch(url + path, {
          method: "POST",
          headers: {
            "apikey": key,
            "Authorization": "Bearer " + token,
            "Content-Type": "application/json",
          },
          body: JSON.stringify(body),
        }).then(async (res) => {
          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            throw new Error(err?.message || err?.hint || "Request failed (" + res.status + ")");
          }
          return res.json().catch(() => ({}));
        });
      }

      async function approveApplication(id) {
        const membershipNumber = window.prompt("Mitgliedsnummer (optional, Enter = leer lassen):");
        if (membershipNumber === null) return; // cancelled
        try {
          setAdmMessage("Antrag wird genehmigt…");
          await sbAuth("/rest/v1/rpc/approve_membership", {
            p_application_id: id,
            p_membership_number: membershipNumber.trim() || null,
          });
          setAdmMessage("Antrag genehmigt.");
          document.querySelector(".catch-dialog[open]")?.close();
          // Reload the approvals panel to reflect the updated status
          const pattern = window.__ADM_CLUB_SETTINGS__;
          if (pattern && typeof pattern.loadPanel === "function") {
            await pattern.loadPanel("club_settings_approvals", "club_settings_approvals_membership").catch(() => {});
          }
        } catch (err) {
          setAdmMessage("Fehler beim Genehmigen: " + (err?.message || err));
        }
      }

      async function rejectApplication(id) {
        const reason = window.prompt("Ablehnungsgrund (optional):");
        if (reason === null) return; // cancelled
        try {
          setAdmMessage("Antrag wird abgelehnt…");
          await sbAuth("/rest/v1/rpc/reject_membership", {
            p_application_id: id,
            p_rejection_reason: reason.trim() || null,
          });
          setAdmMessage("Antrag abgelehnt.");
          document.querySelector(".catch-dialog[open]")?.close();
          const pattern = window.__ADM_CLUB_SETTINGS__;
          if (pattern && typeof pattern.loadPanel === "function") {
            await pattern.loadPanel("club_settings_approvals", "club_settings_approvals_membership").catch(() => {});
          }
        } catch (err) {
          setAdmMessage("Fehler beim Ablehnen: " + (err?.message || err));
        }
      }

      window.addEventListener("fcp-mask:table-row-click", function (e) {
        const detail = e.detail || {};
        if (detail.panelId !== APPROVALS_PANEL) return;
        const row = detail.row || {};
        if (row.status !== "pending") return;
        const id = String(row.id || "").trim();
        if (!id) return;

        // The dialog opens synchronously after this event — inject buttons on next frame
        requestAnimationFrame(function () {
          const dialog = document.querySelector(".catch-dialog[open]");
          if (!dialog) return;
          const actions = dialog.querySelector(".catch-dialog__actions");
          if (!actions || actions.querySelector("[data-approve-app]")) return; // already injected

          const approveBtn = document.createElement("button");
          approveBtn.type = "button";
          approveBtn.className = "feed-btn";
          approveBtn.dataset.approveApp = id;
          approveBtn.textContent = "Genehmigen";
          approveBtn.addEventListener("click", function () { approveApplication(id); });

          const rejectBtn = document.createElement("button");
          rejectBtn.type = "button";
          rejectBtn.className = "feed-btn feed-btn--ghost";
          rejectBtn.dataset.rejectApp = id;
          rejectBtn.textContent = "Ablehnen";
          rejectBtn.addEventListener("click", function () { rejectApplication(id); });

          actions.prepend(rejectBtn);
          actions.prepend(approveBtn);
        });
      });
    })();

    // -------------------------------------------------------------------------

    window.FcpMaskPageLoader.boot({
      configScriptId: "clubSettingsAdmConfig",
      patternGlobal: "__ADM_CLUB_SETTINGS__",
      rendererFamily: "ADM",
      onMessage: setAdmMessage,
    }).catch((error) => {
      setAdmMessage(error instanceof Error ? error.message : String(error));
    });
  </script>

  <style>
    #clubSettingsAdmRoot {
      min-height: 420px;
    }

    .ofm-mask-stage__status {
      margin: 10px 0 0;
    }
  </style>
</Site>
