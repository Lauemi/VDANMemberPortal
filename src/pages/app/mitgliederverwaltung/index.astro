---
import path from "node:path";
import Site from "../../../layouts/Site.astro";
import { APP } from "../../../config/app";
import { readMaskJsonFile } from "../../../../scripts/fcp-mask-reader.mjs";

const maskFilePath = path.resolve(process.cwd(), "docs/masks/templates/Onboarding/ADM_clubSettings.json");
const resolvedMask = await readMaskJsonFile(maskFilePath);

const admConfig = {
  ...resolvedMask,
  root: "#clubSettingsAdmRoot",
  currentRoles: ["admin", "vorstand", "superadmin"],
  currentScopes: {
    globalUser: true,
    authSystem: true,
    clubReadonly: true,
    clubOverride: true,
    billingSnapshot: true,
    consentAppendOnly: false,
  },
};

const admConfigJson = JSON.stringify(admConfig);
---

<Site title={`Vereinsverwaltung • ${APP.name}`} description="ADM: Vereinsverwaltung" robots="noindex" containerClass="container container--admin-wide">
  <section class="card">
    <div class="card__body">
      <div id="clubSettingsAdmRoot" class="fcp-table-root"></div>
      <p id="clubSettingsAdmMsg" class="small ofm-mask-stage__status" aria-live="polite"></p>
    </div>
  </section>

  <script is:inline src="/js/fcp-mask-process-state.js"></script>
  <script is:inline src="/js/fcp-adm-qfm-contract-hub.js"></script>
  <script is:inline src="/js/fcp-mask-data-resolver.js"></script>
  <script is:inline src="/js/fcp-data-table.js"></script>
  <script is:inline src="/js/fcp-inline-data-table-v2.js"></script>
  <script is:inline src="/js/fcp-adm-qfm-shared-renderers.js"></script>
  <script is:inline src="/js/fcp-table-dialog-host.js"></script>
  <script is:inline src="/js/domain-adapter-vereinsverwaltung.js"></script>
  <script is:inline src="/js/vereinsverwaltung-adm.js"></script>
  <script is:inline src="/js/admin-panel-mask.js"></script>
  <script is:inline src="/js/fcp-mask-page-loader.js"></script>
  <link rel="stylesheet" href="/css/redesign.css" />
  <script is:inline src="/js/redesign.js"></script>
  <script id="clubSettingsAdmConfig" type="application/json" set:html={admConfigJson}></script>
  <script is:inline>
    const admMsgEl = document.getElementById("clubSettingsAdmMsg");

    function setAdmMessage(text) {
      if (admMsgEl) admMsgEl.textContent = text || "";
    }

    window.FcpMaskPageLoader.boot({
      configScriptId: "clubSettingsAdmConfig",
      patternGlobal: "__ADM_CLUB_SETTINGS__",
      rendererFamily: "ADM",
      onMessage: setAdmMessage,
    }).catch((error) => {
      setAdmMessage(error instanceof Error ? error.message : String(error));
    });
  </script>

  <style>
    #clubSettingsAdmRoot {
      min-height: 420px;
    }

    .ofm-mask-stage__status {
      margin: 10px 0 0;
    }
  </style>
</Site>
