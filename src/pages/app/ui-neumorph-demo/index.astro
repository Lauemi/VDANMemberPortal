---
import Site from "../../../layouts/Site.astro";
import { APP } from "../../../config/app";
---

<Site title={`UI Demo • ${APP.name}`} description="Admin: Soft UI Fishing Dashboard Demo" robots="noindex">
  <section class="nm-demo-theme">
    <div class="card__body demo-shell">
      <header class="demo-head">
        <div>
          <h1>Fishing Club UI Demo</h1>
          <p class="small">Soft UI · Outdoor Dashboard Stil</p>
        </div>
        <span class="demo-badge">v2 Direction</span>
      </header>

      <article class="demo-card">
        <h2>Farbschema</h2>
        <div class="palette-grid">
          <div class="swatch-card" style="--sw: var(--color-bg)"><i class="swatch"></i><strong>bg</strong><code>#6C705B</code></div>
          <div class="swatch-card" style="--sw: var(--color-surface)"><i class="swatch"></i><strong>surface</strong><code>#F3EFE5</code></div>
          <div class="swatch-card" style="--sw: var(--color-surface-2)"><i class="swatch"></i><strong>surface-2</strong><code>#DDD4C2</code></div>
          <div class="swatch-card" style="--sw: var(--color-text)"><i class="swatch"></i><strong>text</strong><code>#2F3328</code></div>
          <div class="swatch-card" style="--sw: var(--color-muted)"><i class="swatch"></i><strong>muted</strong><code>#6C705B</code></div>
          <div class="swatch-card" style="--sw: var(--color-primary)"><i class="swatch"></i><strong>primary</strong><code>#595A3D</code></div>
          <div class="swatch-card" style="--sw: var(--color-accent)"><i class="swatch"></i><strong>accent</strong><code>#FFC830</code></div>
          <div class="swatch-card" style="--sw: var(--color-success)"><i class="swatch"></i><strong>success</strong><code>#6B7A45</code></div>
          <div class="swatch-card" style="--sw: var(--color-warning)"><i class="swatch"></i><strong>warning</strong><code>#D9A441</code></div>
          <div class="swatch-card" style="--sw: var(--color-danger)"><i class="swatch"></i><strong>danger</strong><code>#B44E3E</code></div>
        </div>
      </article>

      <article class="demo-card">
        <h2>Token Mapping</h2>
        <div class="token-grid">
          <code>--bg: #6C705B</code>
          <code>--surface: #F3EFE5</code>
          <code>--surface-2: #DDD4C2</code>
          <code>--text: #2F3328</code>
          <code>--muted: #6C705B</code>
          <code>--primary: #595A3D</code>
          <code>--accent: #FFC830</code>
          <code>--success: #6B7A45</code>
          <code>--warning: #D9A441</code>
          <code>--danger: #B44E3E</code>
        </div>
      </article>

      <div class="demo-grid">
        <article class="demo-card">
          <h2>Form Controls</h2>
          <div class="demo-form">
            <label>
              <span>Vereinsname</span>
              <input type="text" value="FCP Ottenheim" />
            </label>
            <label>
              <span>Club-Code</span>
              <input type="text" value="FC01" />
            </label>
            <label>
              <span>Standard-Angelkarte</span>
              <input type="text" value="FCP Standard" />
            </label>
            <label>
              <span>Gewässer</span>
              <select>
                <option>FCP Gewässer 1</option>
                <option>FCP Gewässer 2</option>
              </select>
            </label>
            <label class="switch-row">
              <span>Als public_active_club_id setzen</span>
              <button type="button" class="toggle" aria-pressed="true"><span></span></button>
            </label>
            <div class="actions">
              <button class="btn btn-secondary" type="button">Zurücksetzen</button>
              <button class="btn btn-primary" type="button">Speichern</button>
            </div>
          </div>
        </article>

        <article class="demo-card">
          <h2>Status</h2>
          <div class="status-list">
            <p><span class="chip chip-success">Aktiv</span> Setup validiert</p>
            <p><span class="chip chip-warning">Prüfen</span> Restore-Drill offen</p>
            <p><span class="chip chip-danger">Kritisch</span> Juristische Endfreigabe ausstehend</p>
          </div>
        </article>
      </div>

      <article class="demo-card">
        <h2>Standardisierte Tabelle</h2>
        <p class="small">Kompakte Toolbar, klarer Header, Filter per Icon-Popover.</p>
        <div class="demo-table-shell">
          <div class="table-toolbar" role="region" aria-label="Tabellensteuerung">
            <label class="table-search">
              <span class="visually-hidden">Suche in der Tabelle</span>
              <input id="tableSearchInput" type="search" placeholder="Suche Mitglied, Rolle, Angelkarte, Status..." />
            </label>
            <div class="table-toolbar-actions">
              <span id="activeFilterChip" class="filter-meta hidden-chip">0 Filter aktiv</span>
              <div class="table-view-toggle" role="group" aria-label="Ansicht umschalten">
                <button class="btn btn-secondary btn-mini is-active" type="button" data-view-mode="table">Tabelle</button>
                <button class="btn btn-secondary btn-mini" type="button" data-view-mode="cards">Cards</button>
              </div>
              <button id="resetFiltersBtn" class="btn btn-secondary" type="button">Reset Filter</button>
            </div>
          </div>
          <div class="work-part-table-wrap demo-table-wrap">
            <table class="work-part-table demo-table">
              <thead>
                <tr>
                  <th data-col="member">
                    <span class="th-label">Mitglied</span>
                    <span class="th-actions">
                      <button class="th-icon sort-btn" type="button" data-sort="member" aria-label="Sortieren nach Mitglied">↕</button>
                      <button class="th-icon filter-btn" type="button" data-filter-trigger="member" aria-label="Filter Mitglied">⏷</button>
                    </span>
                    <div class="col-filter" data-col="member">
                      <label>
                        <span>Enthält</span>
                        <input type="text" data-text-filter="member" placeholder="z. B. Vorstand" />
                      </label>
                    </div>
                  </th>
                  <th data-col="role">
                    <span class="th-label">Rolle</span>
                    <span class="th-actions">
                      <button class="th-icon sort-btn" type="button" data-sort="role" aria-label="Sortieren nach Rolle">↕</button>
                      <button class="th-icon filter-btn" type="button" data-filter-trigger="role" aria-label="Filter Rolle">⏷</button>
                    </span>
                    <div class="col-filter" data-col="role">
                      <label>
                        <span>Enthält</span>
                        <input type="text" data-text-filter="role" placeholder="z. B. Mitglied" />
                      </label>
                    </div>
                  </th>
                  <th data-col="card">
                    <span class="th-label">Angelkarte</span>
                    <span class="th-actions">
                      <button class="th-icon sort-btn" type="button" data-sort="card" aria-label="Sortieren nach Angelkarte">↕</button>
                      <button class="th-icon filter-btn" type="button" data-filter-trigger="card" aria-label="Filter Angelkarte">⏷</button>
                    </span>
                    <div class="col-filter" data-col="card">
                      <label>
                        <span>Enthält</span>
                        <input type="text" data-text-filter="card" placeholder="z. B. Standard" />
                      </label>
                    </div>
                  </th>
                  <th data-col="status">
                    <span class="th-label">Status</span>
                    <span class="th-actions">
                      <button class="th-icon sort-btn" type="button" data-sort="status" aria-label="Sortieren nach Status">↕</button>
                      <button class="th-icon filter-btn" type="button" data-filter-trigger="status" aria-label="Filter Status">⏷</button>
                    </span>
                    <div class="col-filter col-filter-status" data-col="status">
                      <p>Status auswählen</p>
                      <label><input type="checkbox" value="aktiv" /> Aktiv</label>
                      <label><input type="checkbox" value="pruefen" /> Prüfen</label>
                      <label><input type="checkbox" value="kritisch" /> Kritisch</label>
                      <div class="col-filter-actions">
                        <button type="button" class="btn btn-secondary btn-mini" data-status-clear>Clear</button>
                        <button type="button" class="btn btn-primary btn-mini" data-status-apply>Apply</button>
                      </div>
                    </div>
                  </th>
                  <th data-col="login">
                    <span class="th-label">Letzter Login</span>
                    <span class="th-actions">
                      <button class="th-icon sort-btn" type="button" data-sort="login" aria-label="Sortieren nach Login">↕</button>
                    </span>
                  </th>
                </tr>
              </thead>
              <tbody id="demoTableBody">
                <tr data-member="Demo Vorstand" data-role="Vorstand" data-card="FCP Standard" data-status="aktiv" data-login="04.03.2026 15:13">
                  <td class="cell-main">Demo Vorstand</td>
                  <td>Vorstand</td>
                  <td>FCP Standard</td>
                  <td><span class="chip chip-success">Aktiv</span></td>
                  <td>04.03.2026 15:13</td>
                </tr>
                <tr data-member="Demo Mitglied" data-role="Mitglied" data-card="FCP Standard" data-status="aktiv" data-login="03.03.2026 20:42">
                  <td class="cell-main">Demo Mitglied</td>
                  <td>Mitglied</td>
                  <td>FCP Standard</td>
                  <td><span class="chip">Aktiv</span></td>
                  <td>03.03.2026 20:42</td>
                </tr>
                <tr data-member="Demo Gewaesserwart" data-role="Mitglied" data-card="FCP Jugend" data-status="pruefen" data-login="02.03.2026 09:08">
                  <td class="cell-main">Demo Gewaesserwart</td>
                  <td>Mitglied</td>
                  <td>FCP Jugend</td>
                  <td><span class="chip chip-warning">Prüfen</span></td>
                  <td>02.03.2026 09:08</td>
                </tr>
                <tr data-member="Demo Schriftfuehrer" data-role="Mitglied" data-card="FCP Standard" data-status="kritisch" data-login="01.03.2026 08:01">
                  <td class="cell-main">Demo Schriftfuehrer</td>
                  <td>Mitglied</td>
                  <td>FCP Standard</td>
                  <td><span class="chip chip-danger">Kritisch</span></td>
                  <td>01.03.2026 08:01</td>
                </tr>
              </tbody>
            </table>
          </div>
          <div id="demoCardList" class="demo-cards-wrap is-hidden" aria-live="polite">
            <article class="demo-data-card" data-member="Demo Vorstand" data-role="Vorstand" data-card="FCP Standard" data-status="aktiv" data-login="04.03.2026 15:13">
              <h3>Demo Vorstand</h3>
              <p><strong>Rolle:</strong> Vorstand</p>
              <p><strong>Angelkarte:</strong> FCP Standard</p>
              <p><strong>Status:</strong> <span class="chip chip-success">Aktiv</span></p>
              <p><strong>Login:</strong> 04.03.2026 15:13</p>
            </article>
            <article class="demo-data-card" data-member="Demo Mitglied" data-role="Mitglied" data-card="FCP Standard" data-status="aktiv" data-login="03.03.2026 20:42">
              <h3>Demo Mitglied</h3>
              <p><strong>Rolle:</strong> Mitglied</p>
              <p><strong>Angelkarte:</strong> FCP Standard</p>
              <p><strong>Status:</strong> <span class="chip">Aktiv</span></p>
              <p><strong>Login:</strong> 03.03.2026 20:42</p>
            </article>
            <article class="demo-data-card" data-member="Demo Gewaesserwart" data-role="Mitglied" data-card="FCP Jugend" data-status="pruefen" data-login="02.03.2026 09:08">
              <h3>Demo Gewaesserwart</h3>
              <p><strong>Rolle:</strong> Mitglied</p>
              <p><strong>Angelkarte:</strong> FCP Jugend</p>
              <p><strong>Status:</strong> <span class="chip chip-warning">Prüfen</span></p>
              <p><strong>Login:</strong> 02.03.2026 09:08</p>
            </article>
            <article class="demo-data-card" data-member="Demo Schriftfuehrer" data-role="Mitglied" data-card="FCP Standard" data-status="kritisch" data-login="01.03.2026 08:01">
              <h3>Demo Schriftfuehrer</h3>
              <p><strong>Rolle:</strong> Mitglied</p>
              <p><strong>Angelkarte:</strong> FCP Standard</p>
              <p><strong>Status:</strong> <span class="chip chip-danger">Kritisch</span></p>
              <p><strong>Login:</strong> 01.03.2026 08:01</p>
            </article>
          </div>
        </div>
      </article>
    </div>
  </section>

  <dialog id="demoRowDialog" class="catch-dialog">
    <form method="dialog" class="catch-dialog__form">
      <h2 id="demoRowDialogTitle">Mitglied</h2>
      <div class="catch-dialog__body demo-row-dialog__body">
        <p><strong>Rolle:</strong> <span id="demoRowRole"></span></p>
        <p><strong>Angelkarte:</strong> <span id="demoRowCard"></span></p>
        <p><strong>Status:</strong> <span id="demoRowStatus"></span></p>
        <p><strong>Letzter Login:</strong> <span id="demoRowLogin"></span></p>
      </div>
      <div class="catch-dialog__actions">
        <button type="submit" class="btn btn-secondary">Schließen</button>
      </div>
    </form>
  </dialog>

  <script>
    const tableBody = document.getElementById("demoTableBody");
    if (tableBody) {
      const rows = Array.from(tableBody.querySelectorAll<HTMLTableRowElement>("tr"));
      const searchInput = document.getElementById("tableSearchInput") as HTMLInputElement | null;
      const resetBtn = document.getElementById("resetFiltersBtn") as HTMLButtonElement | null;
      const activeFilterChip = document.getElementById("activeFilterChip");
      const filterTriggers = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-filter-trigger]"));
      const filterPanels = Array.from(document.querySelectorAll<HTMLElement>(".col-filter"));
      const textInputs = Array.from(document.querySelectorAll<HTMLInputElement>("[data-text-filter]"));
      const statusPanel = document.querySelector<HTMLElement>('.col-filter[data-col="status"]');
      const statusChecks = statusPanel ? Array.from(statusPanel.querySelectorAll<HTMLInputElement>('input[type="checkbox"]')) : [];
      const statusApply = statusPanel?.querySelector<HTMLButtonElement>("[data-status-apply]");
      const statusClear = statusPanel?.querySelector<HTMLButtonElement>("[data-status-clear]");
      const sortButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-sort]"));
      const cardList = document.getElementById("demoCardList");
      const cards = cardList ? Array.from(cardList.querySelectorAll<HTMLElement>(".demo-data-card")) : [];
      const viewButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-view-mode]"));
      const tableWrap = document.querySelector<HTMLElement>(".demo-table-wrap");
      const rowDialog = document.getElementById("demoRowDialog");
      const rowDialogTitle = document.getElementById("demoRowDialogTitle");
      const rowRole = document.getElementById("demoRowRole");
      const rowCard = document.getElementById("demoRowCard");
      const rowStatus = document.getElementById("demoRowStatus");
      const rowLogin = document.getElementById("demoRowLogin");

      const state = {
        search: "",
        text: { member: "", role: "", card: "" },
        status: new Set(),
        sort: { col: "login", dir: "desc" },
        view: "table"
      };

      const parseLogin = (value) => {
        const [d, t] = value.split(" ");
        const [day, month, year] = d.split(".").map((v) => Number(v));
        const [hour, minute] = t.split(":").map((v) => Number(v));
        return new Date(year, month - 1, day, hour, minute).getTime();
      };

      const closePopovers = () => {
        filterPanels.forEach((p) => p.classList.remove("open"));
        filterTriggers.forEach((b) => b.classList.remove("is-active"));
      };

      const updateFilterCount = () => {
        let count = 0;
        if (state.search) count += 1;
        if (state.text.member) count += 1;
        if (state.text.role) count += 1;
        if (state.text.card) count += 1;
        if (state.status.size) count += 1;
        activeFilterChip?.classList.toggle("hidden-chip", count === 0);
        if (activeFilterChip) activeFilterChip.textContent = `${count} Filter aktiv`;
      };

      const applyFilters = () => {
        rows.forEach((row) => {
          const member = (row.dataset.member || "").toLowerCase();
          const role = (row.dataset.role || "").toLowerCase();
          const card = (row.dataset.card || "").toLowerCase();
          const status = (row.dataset.status || "").toLowerCase();
          const login = (row.dataset.login || "").toLowerCase();
          const haystack = `${member} ${role} ${card} ${status} ${login}`;

          const globalMatch = !state.search || haystack.includes(state.search);
          const memberMatch = !state.text.member || member.includes(state.text.member);
          const roleMatch = !state.text.role || role.includes(state.text.role);
          const cardMatch = !state.text.card || card.includes(state.text.card);
          const statusMatch = !state.status.size || state.status.has(status);

          row.hidden = !(globalMatch && memberMatch && roleMatch && cardMatch && statusMatch);
        });

        cards.forEach((card) => {
          const member = (card.dataset.member || "").toLowerCase();
          const role = (card.dataset.role || "").toLowerCase();
          const cardType = (card.dataset.card || "").toLowerCase();
          const status = (card.dataset.status || "").toLowerCase();
          const login = (card.dataset.login || "").toLowerCase();
          const haystack = `${member} ${role} ${cardType} ${status} ${login}`;

          const globalMatch = !state.search || haystack.includes(state.search);
          const memberMatch = !state.text.member || member.includes(state.text.member);
          const roleMatch = !state.text.role || role.includes(state.text.role);
          const cardMatch = !state.text.card || cardType.includes(state.text.card);
          const statusMatch = !state.status.size || state.status.has(status);

          card.hidden = !(globalMatch && memberMatch && roleMatch && cardMatch && statusMatch);
        });
        updateFilterCount();
      };

      const sortRows = (col, dir) => {
        const sorted = [...rows].sort((a, b) => {
          const av = (a.dataset[col] || "").toLowerCase();
          const bv = (b.dataset[col] || "").toLowerCase();
          let result = 0;
          if (col === "login") {
            result = parseLogin(a.dataset.login || "") - parseLogin(b.dataset.login || "");
          } else {
            result = av.localeCompare(bv, "de");
          }
          return dir === "asc" ? result : -result;
        });
        sorted.forEach((row) => tableBody.appendChild(row));
        const sortedCards = [...cards].sort((a, b) => {
          const av = (a.dataset[col] || "").toLowerCase();
          const bv = (b.dataset[col] || "").toLowerCase();
          let result = 0;
          if (col === "login") {
            result = parseLogin(a.dataset.login || "") - parseLogin(b.dataset.login || "");
          } else {
            result = av.localeCompare(bv, "de");
          }
          return dir === "asc" ? result : -result;
        });
        sortedCards.forEach((card) => cardList?.appendChild(card));
      };

      const applyView = () => {
        const showCards = state.view === "cards";
        tableWrap?.classList.toggle("is-hidden", showCards);
        cardList?.classList.toggle("is-hidden", !showCards);
        viewButtons.forEach((btn) => {
          const isActive = btn.getAttribute("data-view-mode") === state.view;
          btn.classList.toggle("is-active", isActive);
        });
      };

      const openRowDialog = (source) => {
        if (!rowDialog || !(rowDialog instanceof HTMLDialogElement)) return;
        const member = source?.dataset?.member || "-";
        const role = source?.dataset?.role || "-";
        const card = source?.dataset?.card || "-";
        const status = source?.dataset?.status || "-";
        const login = source?.dataset?.login || "-";
        if (rowDialogTitle) rowDialogTitle.textContent = member;
        if (rowRole) rowRole.textContent = role;
        if (rowCard) rowCard.textContent = card;
        if (rowStatus) rowStatus.textContent = status;
        if (rowLogin) rowLogin.textContent = login;
        rowDialog.showModal();
      };

      searchInput?.addEventListener("input", (e) => {
        const input = e.currentTarget as HTMLInputElement;
        state.search = String(input.value || "").trim().toLowerCase();
        applyFilters();
      });

      textInputs.forEach((input) => {
        input.addEventListener("input", () => {
          const key = String(input.getAttribute("data-text-filter"));
          state.text[key] = String(input.value || "").trim().toLowerCase();
          const trigger = document.querySelector(`[data-filter-trigger="${key}"]`);
          trigger?.classList.toggle("has-filter", Boolean(state.text[key]));
          applyFilters();
        });
      });

      statusApply?.addEventListener("click", () => {
        state.status.clear();
        statusChecks.forEach((cb) => {
          if (cb.checked) state.status.add(cb.value);
        });
        const statusTrigger = document.querySelector('[data-filter-trigger="status"]');
        statusTrigger?.classList.toggle("has-filter", state.status.size > 0);
        applyFilters();
        closePopovers();
      });

      statusClear?.addEventListener("click", () => {
        statusChecks.forEach((cb) => {
          cb.checked = false;
        });
        state.status.clear();
        document.querySelector('[data-filter-trigger="status"]')?.classList.remove("has-filter");
        applyFilters();
      });

      sortButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const col = String(btn.getAttribute("data-sort"));
          const dir = state.sort.col === col && state.sort.dir === "asc" ? "desc" : "asc";
          state.sort = { col, dir };
          sortButtons.forEach((b) => b.classList.remove("is-active"));
          btn.classList.add("is-active");
          btn.textContent = dir === "asc" ? "↑" : "↓";
          sortRows(col, dir);
        });
      });

      filterTriggers.forEach((trigger) => {
        trigger.addEventListener("click", (e) => {
          e.stopPropagation();
          const col = trigger.getAttribute("data-filter-trigger");
          const panel = document.querySelector(`.col-filter[data-col="${col}"]`);
          const open = panel?.classList.contains("open");
          closePopovers();
          if (!open) {
            panel?.classList.add("open");
            trigger.classList.add("is-active");
          }
        });
      });

      filterPanels.forEach((panel) => {
        panel.addEventListener("click", (e) => e.stopPropagation());
      });

      resetBtn?.addEventListener("click", () => {
        state.search = "";
        state.text.member = "";
        state.text.role = "";
        state.text.card = "";
        state.status.clear();
        if (searchInput) searchInput.value = "";
        textInputs.forEach((input) => {
          input.value = "";
        });
        statusChecks.forEach((cb) => {
          cb.checked = false;
        });
        filterTriggers.forEach((b) => b.classList.remove("has-filter"));
        closePopovers();
        applyFilters();
      });

      viewButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          state.view = String(btn.getAttribute("data-view-mode") || "table");
          applyView();
        });
      });

      rows.forEach((row) => {
        row.addEventListener("click", () => openRowDialog(row));
      });
      cards.forEach((card) => {
        card.addEventListener("click", () => openRowDialog(card));
      });

      document.addEventListener("click", closePopovers);
      sortRows("login", "desc");
      applyFilters();
      applyView();
    }
  </script>

  <style>
    .nm-demo-theme {
      --color-bg: #6c705b;
      --color-surface: #f3efe5;
      /* --color-surface-2: #ddd4c2; */
      --color-text: #2f3328;
      --color-muted: #6c705b;
      --color-primary: #595a3d;
      --color-primary-hover: #4b4c33;
      --color-accent: #ffc830;
      --color-accent-hover: #e6b52b;
      --color-success: #6b7a45;
      --color-warning: #d9a441;
      --color-danger: #b44e3e;

      --space-xs: 8px;
      --space-sm: 16px;
      --space-md: 24px;
      --space-lg: 32px;

      background: var(--color-bg);
      border: 1px solid rgba(47, 51, 40, 0.28);
      box-shadow: 0 8px 18px rgba(62, 56, 34, 0.12);
      border-radius: 14px;
      color: var(--color-text);
    }

    .demo-shell { display: grid; gap: var(--space-md); }

    .demo-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-sm);
    }

    .demo-head h1 {
