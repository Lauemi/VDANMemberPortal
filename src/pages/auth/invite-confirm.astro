---
import Site from "../../layouts/Site.astro";
import { APP } from "../../config/app";

const emailParam = Astro.url.searchParams.get("email") ?? "";
const safeEmail = emailParam.includes("@") ? emailParam : "";
const token = (Astro.url.searchParams.get("token") ?? "").trim();
const hasToken = token.length > 0;
---

<Site
  title={`Zugang aktivieren • ${APP.name}`}
  description="Aktiviere deinen Vereinszugang."
  robots="noindex"
  density="compact"
>
  {hasToken ? (
    <section class="card ui-card register-flow-card form-shell" style="max-width:460px;margin:0 auto;">
      <div class="card__body ui-card__body register-flow">
        <div class="register-flow__intro">
          <h1>Zugang aktivieren</h1>
          <p id="inviteGreeting" class="register-flow__lede">Einladung wird geprüft …</p>
        </div>
        <p id="inviteClaimStatus" class="small" aria-live="polite" hidden></p>
        <div class="register-flow__form form-shell__section">
          <p id="inviteVerifyHint" class="small register-flow__lede"></p>
          <div class="register-flow__actions">
            <button id="inviteVerifyBtn" class="feed-btn fcp-brand-btn--primary" type="button" hidden>Per E-Mail verifizieren</button>
            <span id="inviteClaimMsg" class="small" aria-live="polite"></span>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class="card ui-card register-flow-card form-shell" style="max-width:480px;margin:0 auto;">
      <div class="card__body ui-card__body register-flow">
        <div class="register-flow__intro">
          <h1>E-Mail bestätigt</h1>
          <p class="small register-flow__lede">Dein Zugang wurde bestätigt. Bitte warte einen Moment, der Vereinsbeitritt wird geprüft.</p>
        </div>
        <p id="inviteClaimStatus" class="small" aria-live="polite" hidden></p>
        <form id="inviteConfirmForm" class="register-flow__form form-shell__section">
          <label class="ui-field">
            <span>E-Mail</span>
            <input id="inviteConfirmEmail" type="email" autocomplete="username" value={safeEmail} readonly tabindex="-1" />
          </label>
          <label class="ui-field">
            <span>Passwort</span>
            <input id="inviteConfirmPass" name="password" type="password" autocomplete="current-password" required autofocus />
          </label>
          <div class="register-flow__actions">
            <button id="inviteConfirmBtn" class="feed-btn fcp-brand-btn--primary" type="submit">Weiter zum Portal</button>
            <span id="inviteConfirmMsg" class="small" aria-live="polite"></span>
          </div>
        </form>
      </div>
    </section>
  )}
</Site>

<script>
  function setClaimStatus(type: "success" | "error" | "warning", message: string) {
    const el = document.getElementById("inviteClaimStatus");
    if (!el) return;
    el.textContent = message;
    el.removeAttribute("hidden");
    el.style.cssText = type === "error"
      ? "color:var(--color-danger,#c0392b);font-weight:600;"
      : type === "warning"
        ? "color:var(--color-warning,#d35400);font-weight:600;"
        : "color:var(--color-success,#27ae60);";
  }

  // ── Token-Flow (Member-Claim STEP 5) ──────────────────────────────────────
  const __token = new URLSearchParams(window.location.search).get("token")?.trim() || "";
  if (__token) {
    document.addEventListener("DOMContentLoaded", async () => {
      const auth = (window as any)["VDAN_AUTH"];
      const url = String((window as any).__APP_SUPABASE_URL || "").replace(/\/+$/, "");
      const key = String((window as any).__APP_SUPABASE_KEY || "");
      const greeting = document.getElementById("inviteGreeting");
      const hint = document.getElementById("inviteVerifyHint");
      const verifyBtn = document.getElementById("inviteVerifyBtn") as HTMLButtonElement | null;
      const msgEl = document.getElementById("inviteClaimMsg");
      if (!auth) return;
      const msg = (t: string) => { if (msgEl) msgEl.textContent = t; };

      async function rpc(name: string, body: any, bearer?: string) {
        const headers: Record<string, string> = { apikey: key, "Content-Type": "application/json" };
        if (bearer) headers["Authorization"] = "Bearer " + bearer;
        const res = await fetch(url + "/rest/v1/rpc/" + name, { method: "POST", headers, body: JSON.stringify(body) });
        const j = await res.json().catch(() => ([]));
        if (!res.ok) throw new Error((Array.isArray(j) ? j[0]?.message : j?.message) || ("HTTP " + res.status));
        return Array.isArray(j) ? j[0] : j;
      }
      function maskEmail(e: string) {
        const [u, d] = String(e || "").split("@");
        if (!d) return "deiner hinterlegten Adresse";
        const um = u.length <= 2 ? u[0] + "*" : u[0] + "***" + u[u.length - 1];
        return um + "@" + d;
      }

      // Kontext laden
      let pv: any;
      try { pv = await rpc("member_invite_preview", { p_token: __token }); }
      catch (e: any) { setClaimStatus("error", String(e?.message || "Einladung konnte nicht geladen werden.")); return; }
      if (!pv?.ok) { setClaimStatus("error", pv?.message || "Einladung ungültig."); return; }
      if (greeting) greeting.textContent = `Hallo ${pv.first_name || ""}, aktiviere deinen Zugang zu ${pv.club_name || "deinem Verein"}.`;

      // Zurück vom Magic-Link? → Session vorhanden → Identität bewiesen → claimen
      const bearer = String(auth.loadSession?.()?.access_token || "").trim();
      if (bearer) {
        setClaimStatus("success", "E-Mail bestätigt. Aktiviere Zugang …");
        try {
          const claim = await rpc("member_invite_claim", { p_token: __token }, bearer);
          if (!claim?.ok) { setClaimStatus("error", claim?.message || "Aktivierung fehlgeschlagen."); return; }
          window.location.assign("/app/zugang-pruefen/?next=" + encodeURIComponent("/app/"));
        } catch (err: any) { setClaimStatus("error", String(err?.message || "Aktivierung fehlgeschlagen.")); }
        return;
      }

      // Noch nicht verifiziert → Bestätigungslink an die HINTERLEGTE Adresse (Sicherheitsanker)
      if (!pv.has_email) {
        setClaimStatus("warning", "Für dich ist keine E-Mail hinterlegt. Bitte beim Vorstand melden, dann wird dein Zugang freigeschaltet.");
        return;
      }
      if (hint) hint.textContent = `Zur Bestätigung senden wir einen Link an deine hinterlegte Adresse (${maskEmail(pv.member_email)}). Nur über diesen Link wird dein Zugang aktiviert.`;
      if (verifyBtn) {
        verifyBtn.hidden = false;
        verifyBtn.addEventListener("click", async () => {
          verifyBtn.disabled = true;
          msg("Sende Bestätigung …");
          try {
            const redirectTo = window.location.origin + "/auth/invite-confirm?token=" + encodeURIComponent(__token);
            const res = await fetch(url + "/auth/v1/otp?redirect_to=" + encodeURIComponent(redirectTo), {
              method: "POST",
              headers: { apikey: key, "Content-Type": "application/json" },
              body: JSON.stringify({ email: pv.member_email, create_user: true }),
            });
            if (!res.ok) { const e = await res.json().catch(() => ({})); throw new Error(e?.msg || e?.error_description || ("HTTP " + res.status)); }
            setClaimStatus("success", `Bestätigungs-Mail an ${maskEmail(pv.member_email)} gesendet. Öffne den Link in der Mail, um deinen Zugang zu aktivieren.`);
            msg("");
          } catch (err: any) {
            msg(String(err?.message || "Senden fehlgeschlagen."));
            verifyBtn.disabled = false;
          }
        });
      }
    });
  }

  // ── Legacy-Flow (Post-Auth Claim, ohne token) ─────────────────────────────
  if (!__token) {
    document.addEventListener("DOMContentLoaded", async () => {
      const auth = (window as any)["VDAN_AUTH"];
      const form = document.getElementById("inviteConfirmForm") as HTMLFormElement | null;
      const emailInput = document.getElementById("inviteConfirmEmail") as HTMLInputElement | null;
      const passInput = document.getElementById("inviteConfirmPass") as HTMLInputElement | null;
      const msg = document.getElementById("inviteConfirmMsg");
      const btn = document.getElementById("inviteConfirmBtn") as HTMLButtonElement | null;
      if (!form || !auth) return;

      const email = String(emailInput?.value || "").trim();
      if (!email) {
        setClaimStatus("error", "Kein E-Mail-Kontext. Bitte den Invite-Link erneut verwenden.");
        if (btn) btn.disabled = true;
        return;
      }

      let hasPendingInvite = false;
      try { hasPendingInvite = Boolean(localStorage.getItem(String(auth.INVITE_PENDING_KEY || ""))); } catch { /* ignore */ }

      if (hasPendingInvite) {
        const session = auth.loadSession();
        const token = String(session?.access_token || "").trim();
        if (!token) {
          setClaimStatus("warning", "Sitzung konnte nicht geladen werden. Bitte den Invite-Link erneut oeffnen.");
        } else {
          const sessionEmail = String((session as any)?.user?.email || "").trim().toLowerCase();
          if (sessionEmail && email && sessionEmail !== email.toLowerCase()) {
            setClaimStatus("error", "Sitzungskonflikt: Die aktive Sitzung gehört zu einer anderen E-Mail-Adresse (" + sessionEmail + "). Bitte ein Inkognito-Fenster verwenden und den Einladungslink erneut öffnen.");
            if (btn) btn.disabled = true;
            return;
          }
          try {
            await auth.claimPendingInviteIfPresent(token);
            setClaimStatus("success", "Vereinsbeitritt erfolgreich abgeschlossen. Bitte Passwort eingeben zum Einloggen.");
          } catch (err: any) {
            const message = auth.mapRegistrationErrorMessage ? auth.mapRegistrationErrorMessage(err) : mapClaimError(err);
            setClaimStatus("error", message);
          }
        }
      } else {
        setClaimStatus("success", "E-Mail bestaetigt. Bitte Passwort eingeben zum Einloggen.");
      }

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const pass = String(passInput?.value || "");
        if (!pass) return;
        if (btn) btn.disabled = true;
        if (msg) msg.textContent = "…";
        try {
          await auth.loginWithPassword(email, pass);
          window.location.assign("/app/zugang-pruefen/?next=" + encodeURIComponent("/app/"));
        } catch (err: any) {
          if (msg) msg.textContent = String(err?.message || "Anmeldung fehlgeschlagen.");
          if (btn) btn.disabled = false;
        }
      });
    });
  }

  function mapClaimError(err: any): string {
    const message = String(err?.message || "").trim();
    if (message === "member_email_missing") return "Fuer diese Mitgliedsnummer ist im Verein keine E-Mail-Adresse hinterlegt. Bitte wende dich an den Verein.";
    if (message === "member_email_mismatch") return "Diese E-Mail-Adresse passt nicht zum Mitgliedsdatensatz im Verein.";
    if (message === "member_no_not_found_in_club") return "Diese Mitgliedsnummer wurde im Verein nicht gefunden.";
    if (message === "invite_expired" || message === "invite_invalid" || message === "invite_inactive" || message === "invite_exhausted") return "Diese Einladung ist abgelaufen oder nicht mehr gueltig.";
    return "Dein Konto wurde bestaetigt, aber der Vereinsbeitritt konnte nicht abgeschlossen werden. Bitte wende dich an den Verein.";
  }
</script>
