---
import Site from "../layouts/Site.astro";
---

<Site title="Fishing-Club-Portal" description="Fishing-Club-Portal - hier entsteht die neue Plattform.">
  <section class="coming-soon" aria-labelledby="comingSoonTitle">
    <div class="coming-soon__card">
      <picture class="coming-soon__logo-wrap">
        <source srcset="/Branding/WEBSVGLogo-Fishing-Club-Portal.svg" type="image/svg+xml" />
        <img
          class="coming-soon__logo"
          src="/Branding/WEBLOGOPNGLogo-Fishing-Club-Portal.png"
          alt="Fishing-Club-Portal"
          loading="eager"
        />
      </picture>
      <p class="coming-soon__eyebrow">Fishing-Club-Portal</p>
      <h1 id="comingSoonTitle">Hier entsteht die neue Plattform</h1>
      <p class="small">
        Wir bauen den nächsten Ausbaustand für Vereine. Die öffentliche Seite wird aktuell vorbereitet.
      </p>
      <p class="small">Für Rückfragen: <a href="mailto:info@fishing-club-portal.de">info@fishing-club-portal.de</a></p>
    </div>
  </section>

  <style>
    .coming-soon {
      min-height: clamp(60vh, 70vh, 76vh);
      display: grid;
      place-items: center;
      padding: clamp(16px, 4vw, 32px);
    }

    .coming-soon__card {
      width: min(760px, 100%);
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: clamp(18px, 4vw, 40px);
      text-align: center;
      background:
        radial-gradient(circle at top, rgba(95, 153, 220, 0.2), transparent 50%),
        linear-gradient(180deg, rgba(20, 26, 36, 0.96), rgba(11, 16, 24, 0.96));
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
    }

    .coming-soon__logo-wrap {
      display: flex;
      justify-content: center;
      margin-bottom: 14px;
    }

    .coming-soon__logo {
      display: block;
      width: min(420px, 82%);
      height: auto;
      object-fit: contain;
    }

    .coming-soon__eyebrow {
      margin: 0 0 8px;
      color: var(--muted);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-size: 0.78rem;
      font-weight: 700;
    }

    .coming-soon h1 {
      margin-bottom: 10px;
    }
  </style>
</Site>
