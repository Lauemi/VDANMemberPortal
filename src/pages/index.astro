---
import Site from "../layouts/Site.astro";
import { APP } from "../config/app";
import { resolveSiteMode } from "../config/site-mode";
import pkg from "../../package.json";

function envText(value: unknown, fallback: string) {
  const text = String(value ?? "").trim();
  return text || fallback;
}

const isFcp = resolveSiteMode(Astro.url.hostname, APP.siteMode) === "fcp";
const isFcpLockdown = String(import.meta.env.PUBLIC_SITE_LOCKDOWN ?? "false").trim().toLowerCase() === "true";
const appVersionEnv = String(import.meta.env.PUBLIC_APP_VERSION ?? "").trim();
const deploySha = envText(
  import.meta.env.PUBLIC_DEPLOY_SHA,
  envText(import.meta.env.VERCEL_GIT_COMMIT_SHA, envText(import.meta.env.GITHUB_SHA, "")),
);
const deployRef = envText(
  import.meta.env.PUBLIC_DEPLOY_REF,
  envText(import.meta.env.VERCEL_GIT_COMMIT_REF, envText(import.meta.env.GITHUB_REF_NAME, "")),
);
const buildStamp = envText(import.meta.env.PUBLIC_BUILD_STAMP, "");
const autoAppVersion = [
  `v${String(pkg?.version || "0.1.0").trim()}`,
  deployRef ? deployRef.replace(/[^a-zA-Z0-9._-]+/g, "-") : "",
  deploySha ? deploySha.slice(0, 7) : buildStamp || "dev-local",
].filter(Boolean).join("+");
const assetVersion = encodeURIComponent(appVersionEnv && appVersionEnv !== "dev-local" ? appVersionEnv : autoAppVersion);
const clubRequestHref = "/verein-anfragen/";
const clubJoinHref = "/login/"; // LEGACY-STILLLEGUNG Schritt 2: war "/vereinssignin/"
---

<Site
  title={isFcp ? `Vereinssoftware für Angelvereine | ${APP.name}` : APP.name}
  description={isFcp
    ? "Fishing-Club-Portal – digitale Vereinsverwaltung für Angelvereine. Mitglieder, Termine, Arbeitseinsätze und Dokumente in einem System. Ab 100 € pro Jahr."
    : "Neuigkeiten aus dem Verein"}
  containerClass={isFcp ? "container--fcp-brand" : "container"}
>
  {isFcp ? (
    isFcpLockdown ? (
      <section class="card" style="max-width:780px;margin:0 auto;">
        <div class="card__body app-portal-guest">
          <picture class="app-portal-guest__logo" aria-hidden="true">
            <source srcset={`/Branding/New_FCP_GoFishing.svg?v=${assetVersion}`} type="image/svg+xml" />
            <img src={`/Branding/New_FCP_GoFishing.png?v=${assetVersion}`} alt="" loading="eager" decoding="async" />
          </picture>
          <h1>Hier entsteht etwas Neues.</h1>
          <p class="app-portal-guest__message">
            Die Plattform wird aktuell aufgebaut. Bitte später wieder vorbeischauen.
          </p>
        </div>
      </section>
    ) : (
      <div class="fcp-brand-home">

        {/* ── HERO ─────────────────────────────────────────────────── */}
        <section class="fcp-brand-hero" aria-label="Fishing-Club-Portal – Vereinssoftware für Angelvereine">
          <div class="fcp-brand-hero__media">
            <img src="/Bilder/Hero1.jpg" alt="Angelruten am See bei intensivem Sonnenaufgang" loading="eager" decoding="async" />
          </div>
          <div class="fcp-brand-hero__overlay" aria-hidden="true"></div>
          <div class="container fcp-brand-hero__content">
            <div class="fcp-brand-kicker">Vereinssoftware für Angelvereine</div>
            <h1>Weniger Chaos im Verein.<br />Mehr Zeit zum Angeln.</h1>
            <p>
              Mitglieder, Termine, Arbeitseinsätze und Dokumente — in einem Portal statt verteilt
              über WhatsApp, Excel und Papier. Ab&nbsp;100&nbsp;€ pro Jahr für den ganzen Verein.
            </p>
            <div class="fcp-brand-hero__actions">
              <a class="feed-btn fcp-brand-btn--primary" href={clubRequestHref}>Jetzt Verein anmelden</a>
              <a class="feed-btn feed-btn--ghost fcp-brand-btn--ghost" href="#wie-es-funktioniert">Wie es funktioniert</a>
            </div>
            <ul class="fcp-brand-hero__trust">
              <li>Keine Einrichtungsgebühr</li>
              <li>Setup in einem Tag</li>
              <li>Jährlich kündbar</li>
            </ul>
          </div>
        </section>

        {/* ── PAIN — Was FCP ersetzt ───────────────────────────────── */}
        <section class="fcp-brand-pain" aria-labelledby="pain-hl">
          <div class="container">
            <span class="fcp-brand-kicker--light">Das kennt jeder Verein</span>
            <h2 id="pain-hl">WhatsApp, Excel, Papierlisten.<br />Und trotzdem Chaos.</h2>
            <div class="fcp-brand-pain__grid">
              <div class="fcp-brand-pain-item">
                <span class="fcp-brand-pain-item__icon" aria-hidden="true">💬</span>
                <strong>Chat-Gruppen</strong>
                <p>Termine verschwinden im Chat. Wer hat zugesagt? Wer kommt zum Arbeitseinsatz? Niemand weiß es sicher.</p>
              </div>
              <div class="fcp-brand-pain-item">
                <span class="fcp-brand-pain-item__icon" aria-hidden="true">📊</span>
                <strong>Excel-Tabellen</strong>
                <p>Mitgliederliste von vor zwei Jahren. Bezahlt oder nicht? Wer ist noch aktiv? Jeder führt seine eigene Version.</p>
              </div>
              <div class="fcp-brand-pain-item">
                <span class="fcp-brand-pain-item__icon" aria-hidden="true">📋</span>
                <strong>Papier & PDFs</strong>
                <p>Arbeitseinsätze auf Listen, Fangmeldungen auf Formularen, Ausweise beim Drucker. Alles ein eigenes System.</p>
              </div>
              <div class="fcp-brand-pain-item fcp-brand-pain-item--solution">
                <span class="fcp-brand-pain-item__icon" aria-hidden="true">⚡</span>
                <strong>Mit FCP — ein Portal</strong>
                <p>Mitglieder, Termine, Einsätze, Ausweise, Dokumente. Alles an einem Ort. Ein Login für den ganzen Verein.</p>
              </div>
            </div>
          </div>
        </section>

        {/* ── FEATURES ─────────────────────────────────────────────── */}
        <section class="fcp-brand-band" aria-labelledby="features-hl">
          <div class="container">
            <h2 id="features-hl" class="fcp-brand-section-headline">Was FCP für deinen Angelverein macht</h2>
            <div class="fcp-brand-card-grid">
              <article class="fcp-brand-card">
                <span class="fcp-brand-card__eyebrow">Mitgliederverwaltung</span>
                <h3>Mitgliederliste, Import, digitale Ausweise.</h3>
                <p>CSV-Import, Rollenvergabe, Mitgliedskarten — geführt, ohne Datenpflege-Chaos. Ausweise direkt im Portal, immer aktuell.</p>
              </article>
              <article class="fcp-brand-card">
                <span class="fcp-brand-card__eyebrow">Termine & Arbeitseinsätze</span>
                <h3>Kein Nachrichten-Pingpong mehr.</h3>
                <p>Einsätze planen, Helfer zuweisen, Teilnahme bestätigen — alles an einem Ort, ohne WhatsApp-Koordination.</p>
              </article>
              <article class="fcp-brand-card">
                <span class="fcp-brand-card__eyebrow">Gewässer & Fangliste</span>
                <h3>Berechtigungen, Fänge, Regelwerke.</h3>
                <p>Gewässer mit Zugangsregeln verwalten, digitale Fangmeldungen erfassen — strukturiert und mobil nutzbar.</p>
              </article>
              <article class="fcp-brand-card fcp-brand-card--accent">
                <span class="fcp-brand-card__eyebrow">Rollen & Dokumente</span>
                <h3>Jeder sieht, was zu seiner Rolle gehört.</h3>
                <p>Vorstand, Admin und Mitglieder arbeiten im selben System mit klar geregelten Zuständigkeiten. Dokumente zentral, zugänglich.</p>
              </article>
            </div>
          </div>
        </section>

        {/* ── PRICING ──────────────────────────────────────────────── */}
        <section class="fcp-brand-pricing" id="preise" aria-labelledby="pricing-hl">
          <div class="container">
            <span class="fcp-brand-kicker--light">Preise</span>
            <h2 id="pricing-hl">Faire Staffelpreise. Keine versteckten Kosten.</h2>
            <p class="fcp-brand-pricing__sub">
              2&nbsp;€ pro aktivem Mitglied und Jahr — abgerechnet in 50er-Stufen.
              Transparente Kalkulation, kein Kleingedrucktes, keine Einrichtungsgebühr.
            </p>
            <div class="fcp-brand-pricing__grid">
              <div class="fcp-brand-tier">
                <div class="fcp-brand-tier__range">Bis 50 Mitglieder</div>
                <div class="fcp-brand-tier__price">100&nbsp;€<span>/Jahr</span></div>
                <div class="fcp-brand-tier__label">Kleiner Verein</div>
              </div>
              <div class="fcp-brand-tier fcp-brand-tier--featured">
                <div class="fcp-brand-tier__badge">Beliebt</div>
                <div class="fcp-brand-tier__range">Bis 100 Mitglieder</div>
                <div class="fcp-brand-tier__price">200&nbsp;€<span>/Jahr</span></div>
                <div class="fcp-brand-tier__label">Für die meisten Vereine</div>
              </div>
              <div class="fcp-brand-tier">
                <div class="fcp-brand-tier__range">Bis 150 Mitglieder</div>
                <div class="fcp-brand-tier__price">300&nbsp;€<span>/Jahr</span></div>
                <div class="fcp-brand-tier__label">Großer Verein</div>
              </div>
              <div class="fcp-brand-tier">
                <div class="fcp-brand-tier__range">Bis 200 Mitglieder</div>
                <div class="fcp-brand-tier__price">400&nbsp;€<span>/Jahr</span></div>
                <div class="fcp-brand-tier__label">Etablierter Club</div>
              </div>
            </div>
            <p class="fcp-brand-pricing__overflow">
              Mehr als 200 Mitglieder? <a href={clubRequestHref}>Auf Anfrage — wir finden eine faire Lösung.</a>
            </p>
            <div class="fcp-brand-pricing__cta">
              <a class="feed-btn fcp-brand-btn--primary" href={clubRequestHref}>Jetzt Verein anmelden</a>
              <span class="fcp-brand-pricing__trust">Keine Einrichtungsgebühr · Erster Monat inklusive · Jährlich kündbar</span>
            </div>
          </div>
        </section>

        {/* ── HOW IT WORKS ─────────────────────────────────────────── */}
        <section class="fcp-brand-steps" id="wie-es-funktioniert" aria-labelledby="steps-hl">
          <div class="container">
            <span class="fcp-brand-kicker--dark">So startet ein Verein</span>
            <h2 id="steps-hl">Drei Schritte bis zum laufenden Portal.</h2>
            <div class="fcp-brand-steps__grid">
              <div class="fcp-brand-step">
                <div class="fcp-brand-step__num" aria-hidden="true">1</div>
                <h3>Verein anmelden</h3>
                <p>Vereinsdaten eingeben, Antrag absenden. Kein Vertrag vorab, keine Kreditkarte, kein Risiko.</p>
              </div>
              <div class="fcp-brand-step">
                <div class="fcp-brand-step__num" aria-hidden="true">2</div>
                <h3>Setup & Freischaltung</h3>
                <p>Geführter Einstieg: Mitglieder importieren, Gewässer anlegen, Berechtigungen konfigurieren — in einem Tag erledigt.</p>
              </div>
              <div class="fcp-brand-step">
                <div class="fcp-brand-step__num" aria-hidden="true">3</div>
                <h3>Portal läuft</h3>
                <p>Mitglieder einladen, Portal sofort nutzen — mobil erreichbar, direkt verständlich, ohne Schulung.</p>
              </div>
            </div>
          </div>
        </section>

        {/* ── CLOSING CTA ──────────────────────────────────────────── */}
        <section class="fcp-brand-cta-close" aria-labelledby="cta-hl">
          <div class="container fcp-brand-cta-close__inner">
            <h2 id="cta-hl">Bereit für strukturierten Vereinsbetrieb?</h2>
            <p>Erster Monat inklusive. Geführter Start. Kein Risiko.</p>
            <a class="feed-btn fcp-brand-btn--primary" href={clubRequestHref}>Verein jetzt anmelden</a>
          </div>
        </section>

      </div>
    )
  ) : (
  <section class="home-hero-slider" aria-label="Vereinsimpressionen">
    <div class="home-hero-slider__track">
      <figure class="home-hero-slider__slide">
        <img src="/Bilder/headbanner.jpg" alt="VDAN Ottenheim am Gewässer" loading="eager" />
        <figcaption>VDAN Ottenheim</figcaption>
      </figure>
      <figure class="home-hero-slider__slide">
        <img src="/Bilder/20201026_165446.jpg" alt="Abendstimmung am Vereinsgewässer" loading="lazy" />
        <figcaption>Gemeinschaft am Wasser</figcaption>
      </figure>
      <figure class="home-hero-slider__slide">
        <img src="/Bilder/20201026_165447.jpg" alt="Natur und Angelbereich im Verein" loading="lazy" />
        <figcaption>Natur. Verein. Leidenschaft.</figcaption>
      </figure>
      <figure class="home-hero-slider__slide">
        <img src="/Bilder/20201026_165436.jpg" alt="Uferbereich des Vereins" loading="lazy" />
        <figcaption>Willkommen beim VDAN</figcaption>
      </figure>
    </div>
  </section>

  <section class="feed-shell">
    <div class="feed-toolbar">
      <div>
        <h1>Neuigkeiten</h1>
        <p class="small">Aktuelle Beiträge aus dem Verein als Feed.</p>
      </div>
      <button id="feedNewPost" class="feed-btn hidden" type="button" hidden>Neuer Post</button>
    </div>

    <div id="feedComposerHost"></div>
    <div id="feedList" class="feed-list"></div>
    <p id="feedMsg" class="small" aria-live="polite"></p>
  </section>

  <script src="/js/home-feed.js" defer></script>
  )}
</Site>
