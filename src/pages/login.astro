---
import Site from "../layouts/Site.astro";
import { APP } from "../config/app";
import { resolveSiteMode } from "../config/site-mode";

const nextRaw = Astro.url.searchParams.get("next") ?? "/";
const nextTarget = nextRaw.startsWith("/") ? nextRaw : "/";
const showDemoHint = Boolean(import.meta.env.DEV);
const enablePasswordReset = String(import.meta.env.PUBLIC_ENABLE_PASSWORD_RESET || "").toLowerCase() === "true";
const isFcpMode = resolveSiteMode(Astro.url.hostname, APP.siteMode) === "fcp";
---

<Site title={`Login • ${APP.name}`} description="Login zum Memberbereich." robots="noindex" density="compact">
  <section class="card ui-card login-shell form-shell">
    <div class="card__body ui-card__body">
      <div class="login-shell__intro">
        <h1>Login</h1>
      {!isFcpMode && (
        <>
          <p class="small login-shell__legacy-note">
            WICHTIG: Zugänge wie Mitgliedsnummer  <code>001</code> + Passwort funktionieren nur noch kurzzeitig. In den kommenden Wochen werden alle Accounts auf die neue Auth-E-Mail umgestellt. Danach erfolgt der Login nur noch über Auth-E-Mail.
          </p>
        </>
      )}
      </div>

      <form id="loginForm" class="form-shell__section" data-next-target={nextTarget}>
        <label class="ui-field">
          <span>{isFcpMode ? "E-Mail" : "Mitgliedsnummer oder E-Mail"}</span>
          <input
            id="loginMemberNo"
            name="identifier"
            type="text"
            inputmode="email"
            autocomplete="username"
            placeholder="name@beispiel.de"
            required
          />
        </label>
        <label class="ui-field">
          <span>Passwort</span>
          <input id="loginPass" name="password" type="password" autocomplete="current-password" required />
        </label>

        <div class="ui-actions">
          <button class="primary" type="submit">Einloggen</button>
          <span id="loginMsg" class="small" aria-live="polite"></span>
        </div>
      </form>

      {!isFcpMode && (
        <div class="login-shell__links">
          <p class="small">
            {enablePasswordReset
              ? <a href="/passwort-vergessen/">Passwort vergessen?</a>
              : "Passwort vergessen ist vorbereitet, aber aktuell noch deaktiviert."}
          </p>

          <p class="small">
            Registrierung:
            <a href="/registrieren/">Zur Registrierung</a>.
          </p>
          <p class="small">
            Du willst dem Verein beitreten? <a href="/mitglied-werden.html/">Mitglied werden</a>.
          </p>
        </div>
      )}

      {showDemoHint && (
        <>
          <hr />
          
        </>
      )}
    </div>
  </section>

</Site>
