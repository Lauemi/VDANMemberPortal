---
import Site from "../layouts/Site.astro";
import { APP } from "../config/app";

const nextRaw = Astro.url.searchParams.get("next") ?? "/app/";
const nextTarget = nextRaw.startsWith("/") ? nextRaw : "/app/";
---

<Site title={`Registrieren • ${APP.name}`} description="Auth-Account für das Portal erstellen." robots="noindex">
  <section class="card" style="max-width:560px;margin:0 auto;">
    <div class="card__body">
      <h1>Registrieren</h1>
      <p class="small">Hier erstellst du deinen Portal-Account (Auth-User). Das ist getrennt vom Vereins-Bewerbungsprozess.</p>

      <form id="registerForm" data-next-target={nextTarget}>
        <label>
          <span>Vorname</span>
          <input id="registerFirstName" type="text" autocomplete="given-name" />
        </label>
        <label>
          <span>Nachname</span>
          <input id="registerLastName" type="text" autocomplete="family-name" />
        </label>
        <label>
          <span>E-Mail</span>
          <input id="registerEmail" type="email" autocomplete="email" required />
        </label>
        <label>
          <span>Passwort</span>
          <input id="registerPass" type="password" autocomplete="new-password" minlength="8" required />
        </label>
        <label>
          <span>Passwort wiederholen</span>
          <input id="registerPass2" type="password" autocomplete="new-password" minlength="8" required />
        </label>
        <label>
          <span>
            <input id="registerAccept" type="checkbox" required />
            Ich akzeptiere die <a href="/nutzungsbedingungen.html/">Nutzungsbedingungen</a>.
          </span>
        </label>
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <button class="primary" type="submit">Account erstellen</button>
          <a class="feed-btn feed-btn--ghost" href={`/login/?next=${encodeURIComponent(nextTarget)}`}>Zur Anmeldung</a>
          <span id="registerMsg" class="small" aria-live="polite"></span>
        </div>
      </form>

      <p class="small" style="margin-top:12px;">
        Mitgliedschaft im Verein beantragen: <a href="/mitglied-werden.html/">Mitglied werden</a>.
      </p>
    </div>
  </section>
</Site>
