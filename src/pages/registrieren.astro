---
import Site from "../layouts/Site.astro";
import { APP } from "../config/app";

const nextRaw = Astro.url.searchParams.get("next") ?? "/app/";
const nextTarget = nextRaw.startsWith("/") ? nextRaw : "/app/";
---

<Site title={`Registrieren • ${APP.name}`} description="Auth-Account für das Portal erstellen." robots="noindex">
  <section class="card" style="max-width:560px;margin:0 auto;">
    <div class="card__body">
      <h1>Registrieren</h1>
      <p class="small">Die Registrierung ist aktuell deaktiviert.</p>
      <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
        <button class="primary" type="button" disabled aria-disabled="true">Coming soon</button>
        <a class="feed-btn feed-btn--ghost" href={`/login/?next=${encodeURIComponent(nextTarget)}`}>Zur Anmeldung</a>
      </div>
    </div>
  </section>
</Site>
