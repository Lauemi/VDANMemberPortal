---
import Site from "../layouts/Site.astro";
import { APP } from "../config/app";

const nextRaw = Astro.url.searchParams.get("next") ?? "/app/";
const nextTarget = nextRaw.startsWith("/") ? nextRaw : "/app/";
const inviteToken = String(Astro.url.searchParams.get("invite") ?? "").trim();
---

<Site title={`Registrieren • ${APP.name}`} description="Auth-Account für das Portal erstellen." robots="noindex">
  <section class="card" style="max-width:560px;margin:0 auto;">
    <div class="card__body">
      <h1>Registrieren</h1>
      <p class="small">
        Registrierung ist nur mit Einladungs-Token (QR-Code aus Vereins-Setup) möglich.
      </p>

      <form id="registerForm" data-next-target={nextTarget}>
        <label>
          <span>Mitgliedsnummer</span>
          <input id="registerMemberNo" name="member_no" type="text" inputmode="numeric" autocomplete="username" required />
        </label>
        <label>
          <span>Vorname</span>
          <input id="registerFirstName" name="first_name" type="text" autocomplete="given-name" required />
        </label>
        <label>
          <span>Nachname</span>
          <input id="registerLastName" name="last_name" type="text" autocomplete="family-name" required />
        </label>
        <label>
          <span>Einladungs-Token</span>
          <input id="registerInviteToken" name="invite_token" type="text" value={inviteToken} autocomplete="off" required />
        </label>
        <label>
          <span>Passwort</span>
          <input id="registerPass" name="password" type="password" autocomplete="new-password" minlength="8" required />
        </label>
        <label>
          <span>Passwort wiederholen</span>
          <input id="registerPass2" name="password_repeat" type="password" autocomplete="new-password" minlength="8" required />
        </label>
        <label class="small" style="display:flex;gap:8px;align-items:flex-start;">
          <input id="registerAccept" type="checkbox" required />
          <span>Ich akzeptiere die Nutzungsbedingungen.</span>
        </label>
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <button class="primary" type="submit">Registrieren</button>
          <a class="feed-btn feed-btn--ghost" href={`/login/?next=${encodeURIComponent(nextTarget)}`}>Zur Anmeldung</a>
          <span id="registerMsg" class="small" aria-live="polite"></span>
        </div>
      </form>

      <div class="small" style="margin-top:10px;">
        Kein Token? Bitte Admin fragen und QR-Link aus dem Vereins-Setup nutzen.
      </div>
    </div>
  </section>
</Site>
