---
import Site from "../layouts/Site.astro";
import { APP } from "../config/app";

const nextRaw = Astro.url.searchParams.get("next") ?? "/app/";
const nextTarget = nextRaw.startsWith("/") ? nextRaw : "/app/";
const inviteToken = String(Astro.url.searchParams.get("invite") ?? "").trim();
const inviteClubId = String(Astro.url.searchParams.get("club_id") ?? "").trim();
const inviteClubCode = String(Astro.url.searchParams.get("club_code") ?? "").trim().toUpperCase();
const inviteClubName = String(Astro.url.searchParams.get("club_name") ?? "").trim();
const loginQuery = new URLSearchParams({ next: nextTarget });
if (inviteToken) loginQuery.set("invite", inviteToken);
if (inviteClubId) loginQuery.set("club_id", inviteClubId);
if (inviteClubCode) loginQuery.set("club_code", inviteClubCode);
if (inviteClubName) loginQuery.set("club_name", inviteClubName);
const clubRequestHref = `/verein-anfragen/?next=${encodeURIComponent(nextTarget)}`;
const clubSignInHref = `/vereinssignin/?next=${encodeURIComponent(nextTarget)}`;
const loginHref = `/login/?${loginQuery.toString()}`;
---

<Site title={`Registrieren • ${APP.name}`} description="Einstieg in den passenden Onboarding-Pfad." robots="noindex" density="compact">
  <section class="card ui-card register-flow-card form-shell" style="max-width:840px;margin:0 auto;">
    <div class="card__body ui-card__body register-flow">
      <div class="register-flow__intro">
        <span class="register-flow__eyebrow">Onboarding</span>
        <div class="register-current-path">Startpunkt wählen</div>
        <h1>Wie möchtest du einsteigen?</h1>
        <p class="small register-flow__lede">
          VereinsSignIn und Verein anfragen sind jetzt die aktiven Einstiege. Wähle direkt den passenden Weg.
        </p>
        <p class="register-flow__context small">
          Bestehende Vereine nutzen Invite und Mitgliedsnummer. Neue Vereine starten aktuell über die Anfrage inklusive Stammdaten, Pending-Status und Freigabeprozess.
        </p>
      </div>

      <div class="register-flow__form form-shell__section">
        <section class="register-step register-step--mode is-active">
          <div class="register-step__head">
            <span class="register-step__index">0</span>
            <div>
              <h2>Getrennte Einstiege</h2>
              <p>Keine Sammelmaske mehr: beide Prozesse starten jetzt mit einer eigenen Maske und eigenem Fokus.</p>
            </div>
          </div>
          <div class="register-mode-grid">
            <a class="register-mode-card" href={clubSignInHref}>
              <span class="register-mode-card__badge">Bestehender Verein</span>
              <span class="register-mode-card__title">VereinsSignIn</span>
              <span class="register-mode-card__copy">Für Invite-Link, Invite-Token und Vereins-Mitgliedsnummer. Direkter Einstieg in den Join-Flow.</span>
            </a>
            <a class="register-mode-card is-active" href={clubRequestHref}>
              <span class="register-mode-card__badge">Neuer Verein</span>
              <span class="register-mode-card__title">Verein anfragen</span>
              <span class="register-mode-card__copy">Aktiver Pfad für neue Vereine, solange der Registrierungs- und Billing-Weg noch zurückgehalten wird.</span>
            </a>
          </div>
        </section>

        <div class="register-flow__actions">
          <a class="feed-btn fcp-brand-btn--primary" href={clubRequestHref}>Verein anfragen</a>
          <a class="feed-btn feed-btn--ghost" href={clubSignInHref}>Zum VereinsSignIn</a>
          <a class="register-flow__secondary-link" href={loginHref}>Zur Anmeldung</a>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const invite = String(params.get("invite") || "").trim();
      const clubId = String(params.get("club_id") || "").trim();
      const clubCode = String(params.get("club_code") || "").trim();
      const clubName = String(params.get("club_name") || "").trim();
      const mode = String(params.get("mode") || "").trim().toLowerCase();
      const next = String(params.get("next") || "/app/").trim();
      const nextSafe = next.startsWith("/") ? next : "/app/";

      const buildJoinQuery = () => {
        const query = new URLSearchParams({ next: nextSafe });
        if (invite) query.set("invite", invite);
        if (clubId) query.set("club_id", clubId);
        if (clubCode) query.set("club_code", clubCode);
        if (clubName) query.set("club_name", clubName);
        return query.toString();
      };

      if (invite) {
        window.location.replace(`/vereinssignin/?${buildJoinQuery()}`);
        return;
      }

      if (mode === "join_club") {
        window.location.replace(`/vereinssignin/?${buildJoinQuery()}`);
        return;
      }

      if (mode === "create_club") {
        window.location.replace(`/verein-anfragen/?next=${encodeURIComponent(nextSafe)}`);
      }
    })();
  </script>
</Site>
