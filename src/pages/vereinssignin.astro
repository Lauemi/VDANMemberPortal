---
import Site from "../layouts/Site.astro";
import { APP } from "../config/app";

const nextRaw = Astro.url.searchParams.get("next") ?? "/app/";
const nextTarget = nextRaw.startsWith("/") ? nextRaw : "/app/";
const inviteToken = String(Astro.url.searchParams.get("invite") ?? "").trim();
const inviteClubId = String(Astro.url.searchParams.get("club_id") ?? "").trim();
const inviteClubCode = String(Astro.url.searchParams.get("club_code") ?? "").trim().toUpperCase();
const inviteClubName = String(Astro.url.searchParams.get("club_name") ?? "").trim();
const hasInviteContext = Boolean(inviteToken || inviteClubId || inviteClubName);
const clubDisplayName = inviteClubName || "Verein";
const loginQuery = new URLSearchParams({ next: nextTarget });
if (inviteToken) loginQuery.set("invite", inviteToken);
if (inviteClubId) loginQuery.set("club_id", inviteClubId);
if (inviteClubCode) loginQuery.set("club_code", inviteClubCode);
if (inviteClubName) loginQuery.set("club_name", inviteClubName);
const loginHref = `/login/?${loginQuery.toString()}`;
---

<Site title={hasInviteContext ? `${clubDisplayName} beitreten • ${APP.name}` : `VereinsSignIn • ${APP.name}`} description="Getrennter Einstieg für bestehende Vereine." robots="noindex" density="compact">
  <section class="card ui-card register-flow-card register-flow-card--invite form-shell" style="max-width:760px;margin:0 auto;">
    <div class="card__body ui-card__body register-flow">
      <div class="register-flow__intro">
        {hasInviteContext ? (
          <>
            <h1>{clubDisplayName} beitreten</h1>
            <p class="small register-flow__lede">Du wurdest eingeladen. Prüfe deine Daten, lege deinen Zugang an und schließe den Beitritt ab.</p>
            <div id="registerInviteContext" class="register-note register-note--invite-context small">
              <strong id="registerInviteContextTitle">Einladung erkannt</strong>
              <span id="registerInviteContextCopy">Du trittst dem Verein {clubDisplayName} bei.</span>
            </div>
            <p class="register-flow__context small">
              Diese Angaben werden für die sichere Zuordnung zu deinem Vereinsprofil benötigt. Nach dem Absenden bestätigst du deine E-Mail und wirst dann zur Erstaktivierung weitergeleitet.
            </p>
            <p class="register-flow__context small">
              Die technische Abwicklung erfolgt über das Fishing Club Portal.
            </p>
          </>
        ) : (
          <>
            <span class="register-flow__eyebrow">Onboarding</span>
            <div id="registerCurrentPathLabel" class="register-current-path">Vereinsbeitritt per Einladung</div>
            <h1 id="registerIntroTitle">Bestehendem Verein beitreten</h1>
            <p id="registerModeHint" class="small register-flow__lede">
              Gib deine Zugangsdaten und Einladungsdaten ein, dann erstellen wir dein Konto.
            </p>
            <p id="registerModeContext" class="register-flow__context small">
              Für neue Vereine gibt es einen separaten Anfragepfad.
            </p>
          </>
        )}
        <a
          id="registerMobileSubmitAnchor"
          class="register-flow__mobile-anchor register-flow__mobile-anchor--submit feed-btn feed-btn--ghost"
          href="#registerSubmitBtn"
          data-anchor-target="registerSubmitBtn"
        >
          Direkt zu Verein beitreten
        </a>
      </div>
      {hasInviteContext && (
        <form id="loginForm" class="register-flow__form form-shell__section register-step register-step--auth is-active" data-next-target={nextTarget}>
          <div class="register-step__head">
            <div>
              <h2>Bereits ein Konto?</h2>
              <p>Logge dich mit deinem bestehenden Zugang ein, um den Invite-Claim ohne neuen Signup fortzusetzen.</p>
            </div>
          </div>
          <div class="register-grid">
            <label class="ui-field">
              <span>E-Mail</span>
              <input id="loginMemberNo" name="identifier" type="text" inputmode="email" autocomplete="username" placeholder="name@beispiel.de" required />
            </label>
            <label class="ui-field">
              <span>Mitgliedsnummer</span>
              <input id="loginInviteMemberNo" name="invite_member_no" type="text" inputmode="text" autocomplete="off" placeholder="z. B. 9999" required />
            </label>
            <label class="ui-field">
              <span>Passwort</span>
              <input id="loginPass" name="password" type="password" autocomplete="current-password" required />
            </label>
          </div>
          <div class="ui-actions">
            <button class="feed-btn feed-btn--ghost" type="submit">Einloggen und Invite fortsetzen</button>
            <span id="loginMsg" class="small" aria-live="polite"></span>
          </div>
          <p class="small"><a href="/passwort-vergessen/">Passwort vergessen?</a></p>
        </form>
      )}

      <form
        id="registerForm"
        class="register-flow__form register-form--invite form-shell__section"
        data-next-target={nextTarget}
        data-register-mode="join_club"
        data-invite-club-id={inviteClubId}
        data-invite-club-code={inviteClubCode}
        data-invite-club-name={inviteClubName}
        data-has-invite-context={hasInviteContext ? "true" : "false"}
      >
        <input id="registerModeValue" type="hidden" name="registration_mode" value="join_club" />

        <section id="registerAuthSection" class="register-step register-step--auth">
          {!hasInviteContext ? (
            <div class="register-step__head">
              <div>
                <h2 id="registerAuthTitle">1. Zugangsdaten</h2>
                <p id="registerAuthCopy">Nutze die E-Mail-Adresse, die in deinem Verein hinterlegt ist.</p>
              </div>
            </div>
          ) : (
            <p class="small register-flow__section-label"><strong>Lege deinen Zugang zum VDAN-Mitgliederportal an.</strong></p>
          )}
          <div class="register-grid">
            <label id="registerEmailField">
              <span>E-Mail</span>
              <input id="registerEmail" name="email" type="email" autocomplete="email" required />
            </label>
            <label id="registerPasswordField">
              <span>Passwort</span>
              <input id="registerPass" name="password" type="password" autocomplete="new-password" minlength="8" required />
            </label>
            <label id="registerPasswordRepeatField">
              <span>Passwort wiederholen</span>
              <input id="registerPass2" name="password_repeat" type="password" autocomplete="new-password" minlength="8" required />
            </label>
          </div>
          <p class="small register-flow__context">Sicherheit: Dein Passwort wird verschlüsselt gespeichert und nie im Klartext übertragen.</p>
          <p id="registerPasswordHint" class="small" aria-live="polite"></p>
        </section>

        <section id="registerJoinSection" class="register-step register-step--join">
          {!hasInviteContext && (
            <div class="register-step__head">
              <div>
                <h2>2. Einladungsdaten</h2>
                <p>Nutze Invite-Link oder Invite-Token zusammen mit deiner Mitgliedsnummer.</p>
              </div>
            </div>
          )}
          {!hasInviteContext && (
            <div id="registerInviteContext" class="register-note register-note--invite-context small hidden" hidden>
              <strong id="registerInviteContextTitle">Einladung erkannt</strong>
              <span id="registerInviteContextCopy"></span>
            </div>
          )}
          {!hasInviteContext && (
            <div class="register-note small">
              Bitte verwende die E-Mail-Adresse, die deinem Verein bereits bekannt ist.
            </div>
          )}
          <div class="register-grid">
            <label id="registerInviteTokenField">
              <span>Einladungs-Token</span>
              <input id="registerInviteToken" name="invite_token" type="text" value={inviteToken} autocomplete="off" />
            </label>
            <label>
              <span>Mitgliedsnummer</span>
              <input id="registerMemberNo" name="member_no" type="text" inputmode="text" autocomplete="username" />
            </label>
          </div>
          {!hasInviteContext && (
            <div class="register-step__foot small">
              Nach dem Auth-Abschluss und der Mailverifikation wirst du auf die Bestätigung deiner beim Verein hinterlegten Daten weitergeleitet, bevor du ins Portal gelangst.
            </div>
          )}
        </section>

        {!hasInviteContext ? (
          <section id="registerLegalSection" class="register-step register-step--legal">
            <div class="register-step__head">
              <div>
                <h2 id="registerLegalTitle">3. Zustimmung</h2>
                <p id="registerLegalCopy">Ohne bestätigte Rechtstexte wird der Vereinsbeitritt nicht abgeschlossen.</p>
              </div>
            </div>
            <label class="small register-check">
              <input id="registerAccept" type="checkbox" required />
              <span>Ich akzeptiere die <a href="/nutzungsbedingungen.html/" target="_blank" rel="noopener noreferrer">Nutzungsbedingungen</a> und die <a href="/datenschutz.html/" target="_blank" rel="noopener noreferrer">Datenschutzerklärung</a>.</span>
            </label>
          </section>
        ) : (
          <div class="register-step--legal-compact">
            <label class="small register-check">
              <input id="registerAccept" type="checkbox" required />
              <span>Ich akzeptiere die <a href="/nutzungsbedingungen.html/" target="_blank" rel="noopener noreferrer">Nutzungsbedingungen</a> und die <a href="/datenschutz.html/" target="_blank" rel="noopener noreferrer">Datenschutzerklärung</a>.</span>
            </label>
          </div>
        )}

        <div class="register-flow__actions">
          <button id="registerSubmitBtn" class="feed-btn fcp-brand-btn--primary" type="submit">
            {hasInviteContext ? "Verein beitreten" : "Konto anlegen"}
          </button>
          <a class="register-flow__secondary-link" href={loginHref}>Zur Anmeldung</a>
          <span id="registerMsg" class="small" aria-live="polite"></span>
        </div>
      </form>
    </div>
  </section>
</Site>
